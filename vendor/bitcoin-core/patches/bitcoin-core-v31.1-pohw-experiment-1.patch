+
+#include <array>
+#include <cstdint>
+
+namespace pohw::experiment1 {
+
+inline constexpr char NETWORK_ID[] = "pohw-experiment-1-full-consensus";
+inline constexpr int FORK_HEIGHT{958016};
+// The first fork block already exists. Activate the collision-resistant replay
+// marker on its successor without reinterpreting prior chain history.
+inline constexpr int REPLAY_MARKER_ACTIVATION_HEIGHT{958018};
+inline constexpr char FORK_HASH[] =
+    "00000000000000000001d0f198da4adf33b597782a36c766685b2f217110cfc8";
+// Height 958017 predates replay-marker activation. Pinning its exact hash closes
+// the only markerless replacement slot without reinterpreting live history.
+inline constexpr char FIRST_FORK_HASH[] =
+    "64d2122b44c111f2f593869ce404117d34c6c830f4390eb70245c11dcc503d01";
+inline constexpr uint64_t BOOTSTRAP_HANDOFF_HASHRATE_HPS{1'000'000'000'000'000ULL};
+inline constexpr int32_t HANDOFF_VERSION_BIT{1 << 27};
+inline constexpr std::array<uint8_t, 4> MESSAGE_START{0xd9, 0x70, 0x38, 0xba};
+inline constexpr uint16_t P2P_PORT{40412};
+inline constexpr uint16_t RPC_PORT{40414};
+
+} // namespace pohw::experiment1
+
+#endif // BITCOIN_POHW_EXPERIMENT_H
