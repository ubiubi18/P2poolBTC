+    bootstrap_parent.nTime = inherited_tip.nTime + consensus.nPowTargetSpacing;
+    bootstrap_parent.nBits = UintToArith256(consensus.powLimit).GetCompact();
+    bootstrap_parent.nVersion = 0x20000000;
+
+    const int64_t refreshed_time{bootstrap_parent.nTime + consensus.nPowTargetSpacing / 4};
+    SetMockTime(refreshed_time);
+    CBlockHeader child;
+    child.nTime = bootstrap_parent.nTime;
+    child.nBits = bootstrap_parent.nBits;
+    child.nVersion = 0x20000000;
+
+    CBlockHeader expected{child};
+    expected.nTime = refreshed_time;
+    const uint32_t expected_bits{GetNextWorkRequired(&bootstrap_parent, &expected, consensus)};
+    BOOST_REQUIRE_NE(expected_bits, child.nBits);
