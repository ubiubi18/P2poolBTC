--- /dev/null
+++ b/src/pohw/replay.h
@@ -0,0 +1,44 @@
+// Copyright (c) 2026 The P2poolBTC contributors
+// Distributed under the MIT software license, see the accompanying
+// file COPYING or http://www.opensource.org/licenses/mit-license.php.
+
+#ifndef BITCOIN_POHW_REPLAY_H
+#define BITCOIN_POHW_REPLAY_H
+
+#include <consensus/params.h>
+#include <primitives/transaction.h>
+#include <script/script.h>
+
+namespace pohw {
+
+/**
+ * Exact fork-only replay marker. OP_RESERVED makes this output unspendable on
+ * Bitcoin mainnet. The PoHW interpreter accepts only this two-byte script,
+ * with an empty scriptSig and witness, after the explicit activation height.
+ */
+inline CScript ReplayMarkerScript()
+{
+    return CScript{} << OP_1 << OP_RESERVED;
+}
+
+inline bool IsReplayMarkerScript(const CScript& script)
+{
+    return script == ReplayMarkerScript();
+}
+
+inline bool ReplayMarkerActive(int height, const Consensus::Params& params)
+{
+    return params.pohw_experiment && height >= params.pohw_replay_marker_activation_height;
+}
+
+inline bool CoinbaseHasReplayMarker(const CTransaction& coinbase)
+{
+    for (const CTxOut& output : coinbase.vout) {
+        if (output.nValue == 0 && IsReplayMarkerScript(output.scriptPubKey)) return true;
+    }
+    return false;
+}
+
+} // namespace pohw
+
+#endif // BITCOIN_POHW_REPLAY_H
