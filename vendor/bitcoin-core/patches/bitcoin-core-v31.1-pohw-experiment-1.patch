+BOOST_AUTO_TEST_CASE(POHW_bootstrap_and_handoff_marker)
+{
+    const auto chain_params{CreateChainParams(*m_node.args, ChainType::POHW)};
+    const auto& consensus{chain_params->GetConsensus()};
+    BOOST_REQUIRE(consensus.pohw_experiment);
+    BOOST_CHECK_EQUAL(consensus.pohw_first_fork_hash.GetHex(), pohw::experiment1::FIRST_FORK_HASH);
+
+    CBlockIndex inherited_tip;
+    inherited_tip.nHeight = consensus.pohw_fork_height;
+    inherited_tip.nTime = 1'784'038'172;
+    inherited_tip.nBits = 0x1702369d;
+    inherited_tip.nVersion = 0x20000000;
+
+    CBlockHeader first_fork;
+    first_fork.nTime = inherited_tip.nTime + consensus.nPowTargetSpacing;
+    const uint32_t first_bits{GetNextWorkRequired(&inherited_tip, &first_fork, consensus)};
+    BOOST_CHECK_EQUAL(first_bits, UintToArith256(consensus.powLimit).GetCompact());
+    BOOST_CHECK(!PoHWTargetMeetsHandoff(first_bits, consensus));
+    BOOST_CHECK_EQUAL(ComputePoHWBlockVersion(&inherited_tip, first_bits, consensus, 0x20000000), 0x20000000);
+
+    CBlockIndex bootstrap_parent;
+    bootstrap_parent.pprev = &inherited_tip;
+    bootstrap_parent.nHeight = consensus.pohw_fork_height + 1;
+    bootstrap_parent.nTime = first_fork.nTime;
+    bootstrap_parent.nBits = first_bits;
+    bootstrap_parent.nVersion = 0x20000000;
+
+    CBlockHeader fast_child;
+    fast_child.nTime = bootstrap_parent.nTime + consensus.nPowTargetSpacing / 4;
+    const uint32_t harder_bits{GetNextWorkRequired(&bootstrap_parent, &fast_child, consensus)};
+    arith_uint256 harder_target;
+    harder_target.SetCompact(harder_bits);
+    BOOST_CHECK(UintToArith256(consensus.powLimit) > harder_target);
+
+    constexpr uint32_t HANDOFF_BITS{0x191ebe9c};
+    BOOST_REQUIRE(PoHWTargetMeetsHandoff(HANDOFF_BITS, consensus));
+    const int32_t marked{ComputePoHWBlockVersion(&bootstrap_parent, HANDOFF_BITS, consensus, 0x20000000)};
+    BOOST_CHECK_NE(marked, 0x20000000);
+    BOOST_CHECK(CheckPoHWBlockVersion(&bootstrap_parent, HANDOFF_BITS, marked, consensus));
+    BOOST_CHECK(!CheckPoHWBlockVersion(&bootstrap_parent, HANDOFF_BITS, 0x20000000, consensus));
+
+    CBlockIndex handoff_parent;
+    handoff_parent.pprev = &bootstrap_parent;
+    handoff_parent.nHeight = consensus.pohw_fork_height + 2;
+    handoff_parent.nTime = fast_child.nTime;
+    handoff_parent.nBits = HANDOFF_BITS;
+    handoff_parent.nVersion = marked;
+    BOOST_CHECK_NE(ComputePoHWBlockVersion(&handoff_parent, first_bits, consensus, 0x20000000), 0x20000000);
+}
