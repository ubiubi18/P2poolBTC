+BOOST_AUTO_TEST_CASE(streams_buffered_file_find_any_byte)
+{
+    const fs::path filename{m_args.GetDataDirBase() / "streams_find_any_tmp"};
+    AutoFile file{fsbridge::fopen(filename, "w+b")};
+    for (uint8_t value = 0; value < 40; ++value) file << value;
+    file.seek(0, SEEK_SET);
+
+    BufferedFile buffered{file, 11, 4};
+    const std::byte first_candidates[]{std::byte{7}, std::byte{3}};
+    buffered.FindAnyByte(first_candidates);
+    BOOST_CHECK_EQUAL(buffered.GetPos(), 3U);
+
+    buffered.SkipTo(4);
+    const std::byte cross_buffer_candidates[]{std::byte{23}, std::byte{17}};
+    buffered.FindAnyByte(cross_buffer_candidates);
+    BOOST_CHECK_EQUAL(buffered.GetPos(), 17U);
+
+    BOOST_CHECK_EXCEPTION(
+        buffered.FindAnyByte(std::span<const std::byte>{}),
+        std::ios_base::failure,
+        [](const std::ios_base::failure& error) {
+            return std::string{error.what()}.find("empty search set") != std::string::npos;
+        });
+
+    BOOST_REQUIRE_EQUAL(file.fclose(), 0);
+    fs::remove(filename);
+}
