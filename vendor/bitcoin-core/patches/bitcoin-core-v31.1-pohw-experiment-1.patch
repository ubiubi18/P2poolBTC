+bool Consensus::CheckPoHWForkReplayProtection(const CTransaction& tx, TxValidationState& state, const CCoinsView& inputs, int nSpendHeight, const Consensus::Params& params)
+{
+    if (!pohw::ReplayMarkerActive(nSpendHeight, params) || tx.IsCoinBase()) return true;
+
+    bool spends_inherited{false};
+    bool spends_replay_marker{false};
+    for (const CTxIn& input : tx.vin) {
+        const std::optional<Coin> coin{inputs.GetCoin(input.prevout)};
+        if (!coin || coin->IsSpent()) {
+            return true; // CheckTxInputs reports the canonical missing-input error.
+        }
+        if (coin->nHeight <= params.pohw_fork_height) {
+            spends_inherited = true;
+        } else if (coin->nHeight >= params.pohw_replay_marker_activation_height &&
+                   coin->IsCoinBase() && coin->out.nValue == 0 &&
+                   pohw::IsReplayMarkerScript(coin->out.scriptPubKey)) {
+            spends_replay_marker = true;
+        }
+    }
+
+    if (spends_inherited && !spends_replay_marker) {
+        return state.Invalid(TxValidationResult::TX_CONSENSUS, "bad-pohw-replay-unprotected",
+                             "an inherited-mainnet spend must consume an activated PoHW replay marker");
+    }
+    return true;
+}
