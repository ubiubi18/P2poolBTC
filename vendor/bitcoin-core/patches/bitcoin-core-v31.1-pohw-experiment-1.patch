+    BOOST_CHECK_EQUAL(child.nTime, refreshed_time);
+    BOOST_CHECK_EQUAL(child.nBits, expected_bits);
+    BOOST_CHECK_EQUAL(child.nVersion, ComputePoHWBlockVersion(&bootstrap_parent, expected_bits, consensus, 0x20000000));
+    SetMockTime(0);
+}
