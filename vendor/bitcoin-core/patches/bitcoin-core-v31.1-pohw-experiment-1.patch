+ * divide for values that do not overflow, and remains exact at the deliberately
+ * easy PoHW bootstrap target.
+ */
+arith_uint256 ScaleTarget(const arith_uint256& target, uint32_t numerator, uint32_t denominator, const arith_uint256& limit)
+{
+    assert(numerator > 0);
+    assert(denominator > 0);
