+inline constexpr uint16_t RPC_PORT{40424};
+
+inline constexpr bool HasConfiguredActivationId()
+{
+    for (const char character : ACTIVATION_ID) {
+        if (character != '0') return true;
+    }
+    return false;
+}
+
+} // namespace pohw::experiment2
+
 #endif // BITCOIN_POHW_EXPERIMENT_H
diff --git a/src/pohw/identity_auth.h b/src/pohw/identity_auth.h
new file mode 100644
index 0000000..a10b3e5
--- /dev/null
+++ b/src/pohw/identity_auth.h
@@ -0,0 +1,334 @@
+// Copyright (c) 2026 The P2poolBTC contributors
+// Distributed under the MIT software license, see the accompanying
+// file COPYING or http://www.opensource.org/licenses/mit-license.php.
+
+#ifndef BITCOIN_POHW_IDENTITY_AUTH_H
+#define BITCOIN_POHW_IDENTITY_AUTH_H
+
+#include <consensus/params.h>
+#include <crypto/sha256.h>
+#include <primitives/block.h>
+#include <pubkey.h>
+#include <script/script.h>
+#include <uint256.h>
+
+#include <algorithm>
+#include <array>
+#include <cstdint>
+#include <limits>
+#include <optional>
+#include <span>
+#include <string>
+#include <string_view>
+#include <vector>
+
+namespace pohw {
+
+inline constexpr std::array<unsigned char, 5> IDENTITY_AUTH_MAGIC{'P', '2', 'I', 'A', '1'};
+inline constexpr std::array<unsigned char, 5> SHARE_WORK_MAGIC{'P', '2', 'S', 'W', '1'};
+inline constexpr unsigned char IDENTITY_AUTH_VERSION{1};
+inline constexpr size_t IDENTITY_AUTH_LEAF_BYTES{99};
+inline constexpr size_t IDENTITY_AUTH_FIXED_BYTES{5 + 1 + 32 + IDENTITY_AUTH_LEAF_BYTES + 4 + 1 + 64};
+
+namespace identity_auth_detail {
+
+inline constexpr std::string_view LEAF_TAG{"P2POOLBTC_IDENA_AUTH_LEAF_V1"};
+inline constexpr std::string_view NODE_TAG{"P2POOLBTC_IDENA_AUTH_NODE_V1"};
+inline constexpr std::string_view TXSET_TAG{"P2POOLBTC_IDENA_AUTH_TXSET_V1"};
+inline constexpr std::string_view OUTPUTS_TAG{"P2POOLBTC_IDENA_AUTH_OUTPUTS_V1"};
+inline constexpr std::string_view SIGNING_TAG{"P2POOLBTC_IDENA_AUTH_SIGNING_V1"};
+
+using HashBytes = std::array<unsigned char, 32>;
+
+inline HashBytes TaggedSha256(std::string_view tag, std::span<const unsigned char> payload)
+{
+    HashBytes result{};
+    const unsigned char separator{0};
+    CSHA256 hasher;
+    hasher.Write(reinterpret_cast<const unsigned char*>(tag.data()), tag.size());
+    hasher.Write(&separator, 1);
+    hasher.Write(payload.data(), payload.size());
+    hasher.Finalize(result.data());
+    return result;
+}
+
+inline void AppendLE32(std::vector<unsigned char>& output, uint32_t value)
+{
+    for (int shift = 0; shift < 32; shift += 8) output.push_back(static_cast<unsigned char>(value >> shift));
+}
+
+inline void AppendLE64(std::vector<unsigned char>& output, uint64_t value)
+{
+    for (int shift = 0; shift < 64; shift += 8) output.push_back(static_cast<unsigned char>(value >> shift));
+}
+
+inline uint32_t ReadLE32(std::span<const unsigned char> bytes)
+{
+    return uint32_t{bytes[0]} | (uint32_t{bytes[1]} << 8) | (uint32_t{bytes[2]} << 16) |
+           (uint32_t{bytes[3]} << 24);
+}
+
+inline uint64_t ReadLE64(std::span<const unsigned char> bytes)
+{
+    uint64_t value{0};
+    for (int index = 7; index >= 0; --index) value = (value << 8) | bytes[index];
+    return value;
+}
+
+inline std::optional<std::span<const unsigned char>> SingleMinimalOpReturnPayload(const CScript& script)
+{
+    if (script.size() < 2 || script[0] != OP_RETURN) return std::nullopt;
+    size_t offset{0};
+    size_t length{0};
+    const unsigned char opcode{script[1]};
+    if (opcode <= 75) {
+        offset = 2;
+        length = opcode;
+    } else if (opcode == OP_PUSHDATA1 && script.size() >= 3 && script[2] >= 76) {
+        offset = 3;
+        length = script[2];
+    } else if (opcode == OP_PUSHDATA2 && script.size() >= 4) {
+        length = uint16_t{script[2]} | (uint16_t{script[3]} << 8);
+        if (length <= 255) return std::nullopt;
+        offset = 4;
+    } else {
+        return std::nullopt;
+    }
+    if (length > std::numeric_limits<size_t>::max() - offset || offset + length != script.size()) return std::nullopt;
+    return std::span<const unsigned char>{script.data() + offset, length};
+}
+
+template <size_t N>
+inline bool StartsWith(std::span<const unsigned char> bytes, const std::array<unsigned char, N>& prefix)
+{
+    return bytes.size() >= N && std::equal(prefix.begin(), prefix.end(), bytes.begin());
+}
+
+inline HashBytes DisplayHashBytes(const uint256& hash)
+{
+    HashBytes result{};
+    std::reverse_copy(hash.begin(), hash.end(), result.begin());
+    return result;
+}
+
+inline HashBytes MerkleParent(const HashBytes& left, const HashBytes& right)
+{
+    std::array<unsigned char, 64> payload{};
+    std::copy(left.begin(), left.end(), payload.begin());
+    std::copy(right.begin(), right.end(), payload.begin() + 32);
+    return TaggedSha256(NODE_TAG, payload);
+}
+
+inline HashBytes TransactionSetHash(const CBlock& block)
+{
+    std::vector<unsigned char> payload;
+    const uint32_t count{block.vtx.empty() ? 0U : static_cast<uint32_t>(block.vtx.size() - 1)};
+    payload.reserve(4 + static_cast<size_t>(count) * 32);
+    AppendLE32(payload, count);
+    for (size_t index = 1; index < block.vtx.size(); ++index) {
+        const auto txid{DisplayHashBytes(block.vtx[index]->GetHash().ToUint256())};
+        payload.insert(payload.end(), txid.begin(), txid.end());
+    }
+    return TaggedSha256(TXSET_TAG, payload);
+}
+
+inline HashBytes CoinbaseOutputsHash(const CTransaction& coinbase)
+{
+    std::vector<const CTxOut*> included;
+    included.reserve(coinbase.vout.size());
+    for (const CTxOut& output : coinbase.vout) {
+        const auto payload{SingleMinimalOpReturnPayload(output.scriptPubKey)};
+        if (payload && StartsWith(*payload, IDENTITY_AUTH_MAGIC)) continue;
+        included.push_back(&output);
+    }
+
+    std::vector<unsigned char> bytes;
+    AppendLE32(bytes, static_cast<uint32_t>(included.size()));
+    for (const CTxOut* output : included) {
+        AppendLE64(bytes, static_cast<uint64_t>(output->nValue));
+        AppendLE32(bytes, static_cast<uint32_t>(output->scriptPubKey.size()));
+        bytes.insert(bytes.end(), output->scriptPubKey.begin(), output->scriptPubKey.end());
+    }
+    return TaggedSha256(OUTPUTS_TAG, bytes);
+}
+
+struct ParsedAuthorization {
+    std::span<const unsigned char> policy_hash;
+    std::span<const unsigned char> leaf;
+    std::span<const unsigned char> mining_pubkey;
+    uint32_t leaf_index;
+    std::span<const unsigned char> siblings;
+    std::span<const unsigned char> signature;
+};
+
+inline size_t RequiredMerkleProofDepth(uint32_t authorized_identity_count)
+{
+    size_t depth{0};
+    uint32_t remaining{authorized_identity_count == 0 ? 0 : authorized_identity_count - 1};
+    while (remaining != 0) {
+        ++depth;
+        remaining >>= 1;
+    }
+    return depth;
+}
+
+inline std::optional<ParsedAuthorization> ParseAuthorization(std::span<const unsigned char> payload, const Consensus::Params& params)
+{
+    if (payload.size() < IDENTITY_AUTH_FIXED_BYTES || !StartsWith(payload, IDENTITY_AUTH_MAGIC) ||
+        payload[5] != IDENTITY_AUTH_VERSION) {
+        return std::nullopt;
+    }
+    const size_t proof_depth{payload[141]};
+    if (params.pohw_identity_auth_identity_count == 0 ||
+        proof_depth != RequiredMerkleProofDepth(params.pohw_identity_auth_identity_count) ||
+        proof_depth > params.pohw_identity_auth_max_proof_depth ||
+        proof_depth > (std::numeric_limits<size_t>::max() - IDENTITY_AUTH_FIXED_BYTES) / 32 ||
+        payload.size() != IDENTITY_AUTH_FIXED_BYTES + proof_depth * 32) {
+        return std::nullopt;
+    }
+    const unsigned char state{payload[58]};
+    if (state != 3 && state != 7 && state != 8) return std::nullopt;
+    const uint32_t sequence{ReadLE32(payload.subspan(123, 4))};
+    const uint64_t registration_block{ReadLE64(payload.subspan(127, 8))};
+    if (sequence == 0 || registration_block == 0) return std::nullopt;
+    return ParsedAuthorization{
+        .policy_hash = payload.subspan(6, 32),
+        .leaf = payload.subspan(38, IDENTITY_AUTH_LEAF_BYTES),
+        .mining_pubkey = payload.subspan(59, 32),
+        .leaf_index = ReadLE32(payload.subspan(137, 4)),
+        .siblings = payload.subspan(142, proof_depth * 32),
+        .signature = payload.last(64),
+    };
+}
+
+inline bool CheckMerkleProof(const ParsedAuthorization& auth, const Consensus::Params& params, HashBytes& leaf_hash)
+{
+    if (auth.leaf_index >= params.pohw_identity_auth_identity_count) return false;
+    leaf_hash = TaggedSha256(LEAF_TAG, auth.leaf);
+    HashBytes current{leaf_hash};
+    uint32_t index{auth.leaf_index};
+    for (size_t offset = 0; offset < auth.siblings.size(); offset += 32) {
+        HashBytes sibling{};
+        std::copy_n(auth.siblings.begin() + offset, 32, sibling.begin());
+        current = (index & 1U) == 0 ? MerkleParent(current, sibling) : MerkleParent(sibling, current);
+        index >>= 1;
+    }
+    return index == 0 && std::equal(current.begin(), current.end(), params.pohw_identity_auth_root.begin());
+}
+
+inline HashBytes SigningHashFromComponents(
+    const HashBytes& activation_id,
+    const std::array<unsigned char, 32>& policy_hash,
+    const HashBytes& leaf_hash,
+    const HashBytes& previous_hash,
+    uint64_t height,
+    int32_t version,
+    uint32_t bits,
+    const HashBytes& txset_hash,
+    const HashBytes& outputs_hash)
+{
+    std::vector<unsigned char> payload;
+    payload.reserve(216);
+    payload.insert(payload.end(), activation_id.begin(), activation_id.end());
+    payload.insert(payload.end(), policy_hash.begin(), policy_hash.end());
+    payload.insert(payload.end(), leaf_hash.begin(), leaf_hash.end());
+    payload.insert(payload.end(), previous_hash.begin(), previous_hash.end());
+    AppendLE64(payload, height);
+    AppendLE32(payload, static_cast<uint32_t>(version));
+    AppendLE32(payload, bits);
+    payload.insert(payload.end(), txset_hash.begin(), txset_hash.end());
+    payload.insert(payload.end(), outputs_hash.begin(), outputs_hash.end());
+    return TaggedSha256(SIGNING_TAG, payload);
+}
+
+inline HashBytes SigningHash(const CBlock& block, int height, const Consensus::Params& params,
+                             const HashBytes& leaf_hash)
+{
+    return SigningHashFromComponents(
+        params.pohw_identity_auth_activation_id,
+        params.pohw_identity_auth_policy_hash,
+        leaf_hash,
+        DisplayHashBytes(block.hashPrevBlock),
+        static_cast<uint64_t>(height),
+        block.nVersion,
+        block.nBits,
+        TransactionSetHash(block),
+        CoinbaseOutputsHash(*block.vtx.front()));
+}
+
+} // namespace identity_auth_detail
+
+inline bool CheckIdentityAuthorizedBlock(const CBlock& block, int height, int64_t median_time_past,
+                                         const Consensus::Params& params, std::string& reject_reason)
+{
+    if (!params.pohw_identity_auth || height < params.pohw_identity_auth_activation_height) return true;
+    if (height > params.pohw_identity_auth_expiry_height) {
+        reject_reason = "bad-pohw-idena-auth-expired";
+        return false;
+    }
+    if (median_time_past < params.pohw_identity_auth_finalized_mtp) {
+        reject_reason = "bad-pohw-idena-auth-before-snapshot";
+        return false;
+    }
+    if (median_time_past >= params.pohw_identity_auth_expiry_mtp) {
+        reject_reason = "bad-pohw-idena-auth-expired";
+        return false;
+    }
+    if (block.vtx.empty() || !block.vtx.front()->IsCoinBase()) {
+        reject_reason = "bad-pohw-idena-auth-coinbase";
+        return false;
+    }
+
+    size_t auth_count{0};
+    size_t share_work_count{0};
+    std::optional<std::span<const unsigned char>> auth_payload;
+    for (const CTxOut& output : block.vtx.front()->vout) {
+        const auto payload{identity_auth_detail::SingleMinimalOpReturnPayload(output.scriptPubKey)};
+        if (!payload) continue;
+        if (identity_auth_detail::StartsWith(*payload, IDENTITY_AUTH_MAGIC)) {
+            ++auth_count;
+            if (output.nValue == 0) auth_payload = payload;
+        }
+        if (identity_auth_detail::StartsWith(*payload, SHARE_WORK_MAGIC)) {
+            ++share_work_count;
+            if (payload->size() != 37) {
+                reject_reason = "bad-pohw-share-work-format";
+                return false;
+            }
+            if (output.nValue != 0) {
+                reject_reason = "bad-pohw-share-work-value";
+                return false;
+            }
+        }
+    }
+    if (auth_count != 1 || !auth_payload) {
+        reject_reason = "bad-pohw-idena-auth-count";
+        return false;
+    }
+    if (params.pohw_identity_auth_require_share_work && share_work_count != 1) {
+        reject_reason = "bad-pohw-share-work-count";
+        return false;
+    }
+    const auto auth{identity_auth_detail::ParseAuthorization(*auth_payload, params)};
+    if (!auth || !std::equal(auth->policy_hash.begin(), auth->policy_hash.end(), params.pohw_identity_auth_policy_hash.begin())) {
+        reject_reason = "bad-pohw-idena-auth-format";
+        return false;
+    }
+    identity_auth_detail::HashBytes leaf_hash{};
+    if (!identity_auth_detail::CheckMerkleProof(*auth, params, leaf_hash)) {
+        reject_reason = "bad-pohw-idena-auth-proof";
+        return false;
+    }
+    const XOnlyPubKey pubkey{auth->mining_pubkey};
+    const auto signing_hash{identity_auth_detail::SigningHash(block, height, params, leaf_hash)};
+    const uint256 message{std::span<const unsigned char>{signing_hash}};
+    if (!pubkey.VerifySchnorr(message, auth->signature)) {
+        reject_reason = "bad-pohw-idena-auth-signature";
+        return false;
+    }
+    return true;
+}
+
+} // namespace pohw
+
+#endif // BITCOIN_POHW_IDENTITY_AUTH_H
