@@ -0,0 +1,277 @@
+// Copyright (c) 2026 The P2poolBTC contributors
+// Distributed under the MIT software license, see the accompanying
+// file COPYING or http://www.opensource.org/licenses/mit-license.php.
+
+#include <boost/test/unit_test.hpp>
+
+#include <kernel/chainparams.h>
+#include <pohw/experiment.h>
+#include <pohw/identity_auth.h>
+#include <primitives/block.h>
+#include <primitives/transaction.h>
+#include <script/script.h>
+#include <uint256.h>
+#include <util/strencodings.h>
+
+#include <string>
+#include <vector>
+
+BOOST_AUTO_TEST_SUITE(pohw_identity_auth_tests)
+
+namespace {
+
+constexpr std::string_view AUTHORIZATION_SCRIPT{
+    ""};
+
+CScript ScriptFromHex(std::string_view hex)
+{
+    const auto bytes{ParseHex(hex)};
+    return CScript{bytes.begin(), bytes.end()};
+}
+
+CBlock AuthorizedBlock()
+{
+    CMutableTransaction coinbase;
+    coinbase.version = 2;
+    coinbase.vin.resize(1);
+    coinbase.vin[0].prevout.SetNull();
+    coinbase.vin[0].scriptSig = CScript{} << 1;
+    coinbase.vout.emplace_back(5'000'000'000, ScriptFromHex("00147777777777777777777777777777777777777777"));
+
+    std::vector<unsigned char> share_work{'P', '2', 'S', 'W', '1'};
+    share_work.insert(share_work.end(), 32, 0x88);
+    coinbase.vout.emplace_back(0, CScript{} << OP_RETURN << share_work);
+    coinbase.vout.emplace_back(0, ScriptFromHex(AUTHORIZATION_SCRIPT));
+
+    CBlock block;
+    block.nVersion = 0x20000000;
+    block.hashPrevBlock = uint256{"5555555555555555555555555555555555555555555555555555555555555555"};
+    block.nTime = pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP + 100;
+    block.nBits = 0x207fffff;
+    block.vtx.push_back(MakeTransactionRef(std::move(coinbase)));
+    return block;
+}
+
+Consensus::Params VectorConsensus()
+{
+    const auto chainparams{CChainParams::PoHW2()};
+    Consensus::Params params{chainparams->GetConsensus()};
+    params.pohw_identity_auth_activation_id.fill(0xaa);
+    return params;
+}
+
+bool Check(const CBlock& block, int height, std::string& reason,
+           int64_t median_time_past = pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP + 100)
+{
+    const auto params{VectorConsensus()};
+    return pohw::CheckIdentityAuthorizedBlock(block, height, median_time_past, params, reason);
+}
+
+} // namespace
+
+BOOST_AUTO_TEST_CASE(successor_params_are_distinct_and_consensus_enforced)
+{
+    const auto predecessor{CChainParams::PoHW()};
+    const auto successor{CChainParams::PoHW2()};
+    const auto& consensus{successor->GetConsensus()};
+    BOOST_CHECK(successor->MessageStart() != predecessor->MessageStart());
+    BOOST_CHECK(successor->GetDefaultPort() != predecessor->GetDefaultPort());
+    BOOST_CHECK(consensus.pohw_identity_auth);
+    BOOST_CHECK_EQUAL(consensus.pohw_identity_auth_activation_height, pohw::experiment2::IDENTITY_AUTH_ACTIVATION_HEIGHT);
+    BOOST_CHECK_EQUAL(consensus.pohw_identity_auth_expiry_height, pohw::experiment2::IDENTITY_AUTH_EXPIRY_HEIGHT);
+    BOOST_CHECK_EQUAL(consensus.pohw_identity_auth_finalized_mtp, pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP);
+    BOOST_CHECK_EQUAL(consensus.pohw_identity_auth_expiry_mtp, pohw::experiment2::IDENTITY_AUTH_EXPIRY_MTP);
+    BOOST_CHECK_EQUAL(consensus.pohw_identity_auth_parent_hash.GetHex(), pohw::experiment2::IDENTITY_AUTH_PARENT_HASH);
+    BOOST_CHECK_EQUAL(HexStr(consensus.pohw_identity_auth_activation_id), pohw::experiment2::ACTIVATION_ID);
+    BOOST_CHECK_EQUAL(HexStr(consensus.pohw_identity_auth_policy_hash), pohw::experiment2::IDENTITY_AUTH_POLICY_HASH);
+    BOOST_CHECK_EQUAL(HexStr(consensus.pohw_identity_auth_root), pohw::experiment2::IDENTITY_AUTH_ROOT);
+}
+
+BOOST_AUTO_TEST_CASE(rust_fixed_vector_is_accepted)
+{
+    std::string reason;
+    const CBlock block{AuthorizedBlock()};
+    const auto params{VectorConsensus()};
+    const auto payload{pohw::identity_auth_detail::SingleMinimalOpReturnPayload(block.vtx.front()->vout.back().scriptPubKey)};
+    BOOST_REQUIRE(payload);
+    const auto auth{pohw::identity_auth_detail::ParseAuthorization(*payload, params)};
+    BOOST_REQUIRE(auth);
+    pohw::identity_auth_detail::HashBytes leaf_hash{};
+    BOOST_REQUIRE(pohw::identity_auth_detail::CheckMerkleProof(*auth, params, leaf_hash));
+    BOOST_CHECK_EQUAL(HexStr(params.pohw_identity_auth_policy_hash), "4f727128f49d0f4cd1e1fcca85cbfcb5b9b5f0f3877787be8d33f4c0384d5ab3");
+    BOOST_CHECK_EQUAL(HexStr(leaf_hash), "571dfda102d64afb00330eb07c929f3eb3c183a5ac11f17ca6ec51f27d7c6b6b");
+    BOOST_CHECK_EQUAL(HexStr(pohw::identity_auth_detail::DisplayHashBytes(block.hashPrevBlock)), std::string(64, '5'));
+    BOOST_CHECK_EQUAL(block.nVersion, 0x20000000);
+    BOOST_CHECK_EQUAL(block.nBits, 0x207fffffU);
+    BOOST_CHECK_EQUAL(HexStr(pohw::identity_auth_detail::TransactionSetHash(block)), "df9a71eb4114cfd21da50ff75e28a82ab23d451ba009253d2d18712dbc013ec3");
+    BOOST_CHECK_EQUAL(HexStr(pohw::identity_auth_detail::CoinbaseOutputsHash(*block.vtx.front())), "675d77960d702e5870df9d1b6723b018395e03c49448dccd7022de1efb569da8");
+    pohw::identity_auth_detail::HashBytes vector_activation_id{};
+    vector_activation_id.fill(0xaa);
+    BOOST_CHECK_EQUAL(
+        HexStr(pohw::identity_auth_detail::SigningHashFromComponents(
+            vector_activation_id,
+            params.pohw_identity_auth_policy_hash,
+            leaf_hash,
+            pohw::identity_auth_detail::DisplayHashBytes(block.hashPrevBlock),
+            958176,
+            0x20000000,
+            0x207fffff,
+            pohw::identity_auth_detail::TransactionSetHash(block),
+            pohw::identity_auth_detail::CoinbaseOutputsHash(*block.vtx.front()))),
+        "f4663bd69894696e26f2f83d0a2424f2901f2f4eb29fac8b83b1f11a3b735d04");
+    const auto configured_activation_id{params.pohw_identity_auth_activation_id};
+    BOOST_CHECK_EQUAL(
+        HexStr(pohw::identity_auth_detail::SigningHash(
+            block,
+            pohw::experiment2::IDENTITY_AUTH_ACTIVATION_HEIGHT,
+            params,
+            leaf_hash)),
+        HexStr(pohw::identity_auth_detail::SigningHashFromComponents(
+            configured_activation_id,
+            params.pohw_identity_auth_policy_hash,
+            leaf_hash,
+            pohw::identity_auth_detail::DisplayHashBytes(block.hashPrevBlock),
+            958176,
+            0x20000000,
+            0x207fffff,
+            pohw::identity_auth_detail::TransactionSetHash(block),
+            pohw::identity_auth_detail::CoinbaseOutputsHash(*block.vtx.front()))));
+    BOOST_CHECK_MESSAGE(
+        pohw::CheckIdentityAuthorizedBlock(
+            block,
+            pohw::experiment2::IDENTITY_AUTH_ACTIVATION_HEIGHT,
+            pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP + 100,
+            params,
+            reason),
+        "authorization rejected: " << reason);
+    BOOST_CHECK(reason.empty());
+}
+
+BOOST_AUTO_TEST_CASE(missing_duplicate_or_malformed_commitments_fail_closed)
+{
+    const int height{pohw::experiment2::IDENTITY_AUTH_ACTIVATION_HEIGHT};
+    std::string reason;
+
+    CBlock missing_auth{AuthorizedBlock()};
+    CMutableTransaction missing_auth_coinbase{*missing_auth.vtx.front()};
+    missing_auth_coinbase.vout.pop_back();
+    missing_auth.vtx[0] = MakeTransactionRef(std::move(missing_auth_coinbase));
+    BOOST_CHECK(!Check(missing_auth, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-count");
+
+    CBlock duplicate_auth{AuthorizedBlock()};
+    CMutableTransaction duplicate_coinbase{*duplicate_auth.vtx.front()};
+    duplicate_coinbase.vout.push_back(duplicate_coinbase.vout.back());
+    duplicate_auth.vtx[0] = MakeTransactionRef(std::move(duplicate_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(duplicate_auth, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-count");
+
+    CBlock nonzero_auth{AuthorizedBlock()};
+    CMutableTransaction nonzero_auth_coinbase{*nonzero_auth.vtx.front()};
+    nonzero_auth_coinbase.vout.back().nValue = 1;
+    nonzero_auth.vtx[0] = MakeTransactionRef(std::move(nonzero_auth_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(nonzero_auth, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-count");
+
+    CBlock missing_share_work{AuthorizedBlock()};
+    CMutableTransaction missing_share_coinbase{*missing_share_work.vtx.front()};
+    missing_share_coinbase.vout.erase(missing_share_coinbase.vout.begin() + 1);
+    missing_share_work.vtx[0] = MakeTransactionRef(std::move(missing_share_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(missing_share_work, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-share-work-count");
+
+    CBlock nonzero_share_work{AuthorizedBlock()};
+    CMutableTransaction nonzero_share_coinbase{*nonzero_share_work.vtx.front()};
+    nonzero_share_coinbase.vout[1].nValue = 1;
+    nonzero_share_work.vtx[0] = MakeTransactionRef(std::move(nonzero_share_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(nonzero_share_work, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-share-work-value");
+
+    CBlock malformed_share_work{AuthorizedBlock()};
+    CMutableTransaction malformed_share_coinbase{*malformed_share_work.vtx.front()};
+    std::vector<unsigned char> malformed_share{'P', '2', 'S', 'W', '1', 0};
+    malformed_share_coinbase.vout.emplace_back(0, CScript{} << OP_RETURN << malformed_share);
+    malformed_share_work.vtx[0] = MakeTransactionRef(std::move(malformed_share_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(malformed_share_work, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-share-work-format");
+
+    CBlock ineligible{AuthorizedBlock()};
+    CMutableTransaction ineligible_coinbase{*ineligible.vtx.front()};
+    auto bytes{std::vector<unsigned char>{ineligible_coinbase.vout.back().scriptPubKey.begin(), ineligible_coinbase.vout.back().scriptPubKey.end()}};
+    bytes[4 + 58] = 2;
+    ineligible_coinbase.vout.back().scriptPubKey = CScript{bytes.begin(), bytes.end()};
+    ineligible.vtx[0] = MakeTransactionRef(std::move(ineligible_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(ineligible, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-format");
+}
+
+BOOST_AUTO_TEST_CASE(proof_signature_outputs_and_expiry_are_bound)
+{
+    const int height{pohw::experiment2::IDENTITY_AUTH_ACTIVATION_HEIGHT};
+    std::string reason;
+
+    const CBlock canonical{AuthorizedBlock()};
+    const auto canonical_payload{pohw::identity_auth_detail::SingleMinimalOpReturnPayload(canonical.vtx.front()->vout.back().scriptPubKey)};
+    BOOST_REQUIRE(canonical_payload);
+    std::vector<unsigned char> short_proof{canonical_payload->begin(), canonical_payload->end()};
+    short_proof[141] = 1;
+    short_proof.erase(short_proof.begin() + 174, short_proof.begin() + 206);
+    BOOST_CHECK(!pohw::identity_auth_detail::ParseAuthorization(short_proof, CChainParams::PoHW2()->GetConsensus()));
+
+    std::vector<unsigned char> long_proof{canonical_payload->begin(), canonical_payload->end()};
+    long_proof[141] = 3;
+    long_proof.insert(long_proof.end() - 64, 32, 0);
+    BOOST_CHECK(!pohw::identity_auth_detail::ParseAuthorization(long_proof, CChainParams::PoHW2()->GetConsensus()));
+
+    CBlock changed_payout{AuthorizedBlock()};
+    CMutableTransaction changed_payout_coinbase{*changed_payout.vtx.front()};
+    changed_payout_coinbase.vout.front().nValue += 1;
+    changed_payout.vtx[0] = MakeTransactionRef(std::move(changed_payout_coinbase));
+    BOOST_CHECK(!Check(changed_payout, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-signature");
+
+    auto substituted_activation{VectorConsensus()};
+    substituted_activation.pohw_identity_auth_activation_id.fill(0xbb);
+    reason.clear();
+    BOOST_CHECK(!pohw::CheckIdentityAuthorizedBlock(
+        AuthorizedBlock(),
+        height,
+        pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP + 100,
+        substituted_activation,
+        reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-signature");
+
+    CBlock changed_proof{AuthorizedBlock()};
+    CMutableTransaction changed_proof_coinbase{*changed_proof.vtx.front()};
+    auto proof_bytes{std::vector<unsigned char>{changed_proof_coinbase.vout.back().scriptPubKey.begin(), changed_proof_coinbase.vout.back().scriptPubKey.end()}};
+    proof_bytes[4 + 142] ^= 1;
+    changed_proof_coinbase.vout.back().scriptPubKey = CScript{proof_bytes.begin(), proof_bytes.end()};
+    changed_proof.vtx[0] = MakeTransactionRef(std::move(changed_proof_coinbase));
+    reason.clear();
+    BOOST_CHECK(!Check(changed_proof, height, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-proof");
+
+    reason.clear();
+    BOOST_CHECK(!Check(AuthorizedBlock(), pohw::experiment2::IDENTITY_AUTH_EXPIRY_HEIGHT + 1, reason));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-expired");
+
+    reason.clear();
+    BOOST_CHECK(!Check(AuthorizedBlock(), height, reason, pohw::experiment2::IDENTITY_AUTH_FINALIZED_MTP - 1));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-before-snapshot");
+
+    reason.clear();
+    BOOST_CHECK(!Check(AuthorizedBlock(), height, reason, pohw::experiment2::IDENTITY_AUTH_EXPIRY_MTP));
+    BOOST_CHECK_EQUAL(reason, "bad-pohw-idena-auth-expired");
+
+    CBlock empty;
+    reason.clear();
+    BOOST_CHECK(Check(empty, height - 1, reason));
+}
+
+BOOST_AUTO_TEST_SUITE_END()
