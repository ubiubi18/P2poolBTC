diff --git a/test/functional/feature_pohw_identity_auth.py b/test/functional/feature_pohw_identity_auth.py
new file mode 100644
index 0000000..728db8f
--- /dev/null
+++ b/test/functional/feature_pohw_identity_auth.py
@@ -0,0 +1,189 @@
+#!/usr/bin/env python3
+# Copyright (c) 2026 The P2poolBTC contributors
+# Distributed under the MIT software license, see the accompanying
+# file COPYING or http://www.opensource.org/licenses/mit-license.php.
+"""Exercise P2IA1 through submitblock and the real ConnectBlock path."""
+
+import hashlib
+import struct
+
+from test_framework.blocktools import create_block, create_coinbase
+from test_framework.key import sign_schnorr
+from test_framework.messages import CTxOut
+from test_framework.script import CScript, OP_RETURN
+from test_framework.test_framework import BitcoinTestFramework
+from test_framework.util import assert_equal
+
+
+ACTIVATION_HEIGHT = 105
+EXPIRY_HEIGHT = 120
+ACTIVATION_ID = "f" * 64
+POLICY_HASH = "4f727128f49d0f4cd1e1fcca85cbfcb5b9b5f0f3877787be8d33f4c0384d5ab3"
+AUTHORIZATION_ROOT = "2430c7f7ab395c27c67ed7d4bfc6e55f4db2cbd72ce8dc1876b1c5ebc9411e38"
+MINING_SECRET = bytes([3]) * 32
+MINING_PUBKEY = "531fe6068134503d2723133227c867ac8fa6c83c537e9a44c3c5bdbdcb1fe337"
+PROOF_SIBLINGS = [
+    "700120a51a4650ccc1193ef4d4a379a79db691390dd66547eb2a7d1788fe37f5",
+    "48332a7eacc21076edca496211fb712f6bc05fb1c3774284e891adc5b949bf37",
+]
+
+
+def tagged_sha256(tag, payload):
+    return hashlib.sha256(tag.encode() + b"\x00" + payload).digest()
+
+
+def authorization_leaf():
+    return b"".join([
+        bytes.fromhex("00" * 19 + "02"),
+        bytes([3]),  # Verified
+        bytes.fromhex(MINING_PUBKEY),
+        bytes.fromhex("00" * 31 + "0c"),
+        struct.pack("<I", 3),
+        struct.pack("<Q", 10002),
+        struct.pack("<H", 122),
+    ])
+
+
+def transaction_set_hash(block):
+    txids = [tx.txid_int.to_bytes(32, "big") for tx in block.vtx[1:]]
+    return tagged_sha256(
+        "P2POOLBTC_IDENA_AUTH_TXSET_V1",
+        struct.pack("<I", len(txids)) + b"".join(txids),
+    )
+
+
+def coinbase_outputs_hash(coinbase):
+    encoded = []
+    for output in coinbase.vout:
+        script = bytes(output.scriptPubKey)
+        if script.startswith(b"\x6a") and b"P2IA1" in script[:6 + len(b"P2IA1")]:
+            continue
+        encoded.append(
+            struct.pack("<Q", output.nValue)
+            + struct.pack("<I", len(script))
+            + script
+        )
+    return tagged_sha256(
+        "P2POOLBTC_IDENA_AUTH_OUTPUTS_V1",
+        struct.pack("<I", len(encoded)) + b"".join(encoded),
+    )
+
+
+def add_authorization(block):
+    leaf = authorization_leaf()
+    leaf_hash = tagged_sha256("P2POOLBTC_IDENA_AUTH_LEAF_V1", leaf)
+    signing_payload = b"".join([
+        bytes.fromhex(ACTIVATION_ID),
+        bytes.fromhex(POLICY_HASH),
+        leaf_hash,
+        block.hashPrevBlock.to_bytes(32, "big"),
+        struct.pack("<Q", ACTIVATION_HEIGHT),
+        struct.pack("<i", block.nVersion),
+        struct.pack("<I", block.nBits),
+        transaction_set_hash(block),
+        coinbase_outputs_hash(block.vtx[0]),
+    ])
+    signing_hash = tagged_sha256(
+        "P2POOLBTC_IDENA_AUTH_SIGNING_V1",
+        signing_payload,
+    )
+    signature = sign_schnorr(MINING_SECRET, signing_hash)
+    payload = b"".join([
+        b"P2IA1",
+        bytes([1]),
+        bytes.fromhex(POLICY_HASH),
+        leaf,
+        struct.pack("<I", 1),
+        bytes([len(PROOF_SIBLINGS)]),
+        b"".join(bytes.fromhex(sibling) for sibling in PROOF_SIBLINGS),
+        signature,
+    ])
+    block.vtx[0].vout.append(CTxOut(0, CScript([OP_RETURN, payload])))
+    block.hashMerkleRoot = block.calc_merkle_root()
+
+
+def candidate_block(node, *, authorized):
+    template = node.getblocktemplate({"rules": ["segwit"]})
+    coinbase = create_coinbase(template["height"])
+    coinbase.vout.append(CTxOut(0, CScript([OP_RETURN, b"P2SW1" + bytes([0x88]) * 32])))
+    block = create_block(coinbase=coinbase, tmpl=template)
+    if authorized:
+        add_authorization(block)
+    block.solve()
+    return block, template
+
+
+class PoHWIdentityAuthorizationTest(BitcoinTestFramework):
+    def set_test_params(self):
+        self.num_nodes = 1
+        self.setup_clean_chain = True
+
+    def run_test(self):
+        node = self.nodes[0]
+        self.generate(node, ACTIVATION_HEIGHT - 1)
+        parent_hash = node.getbestblockhash()
+        predecessor_hash = node.getblockhash(ACTIVATION_HEIGHT - 2)
+        predecessor_time = node.getblock(predecessor_hash)["time"]
+
+        self.restart_node(0, extra_args=[
+            f"-testactivationheight=pohw-identity-auth@{ACTIVATION_HEIGHT}",
+            f"-pohwidentityauthparent={parent_hash}",
+            f"-pohwidentityauthexpiryheight={EXPIRY_HEIGHT}",
+            "-pohwidentityauthfinalizedmtp=0",
+            "-pohwidentityauthexpirymtp=4102444800",
+        ])
+        node = self.nodes[0]
+
+        self.log.info("The RPC template exposes the exact consensus authorization profile")
+        _, template = candidate_block(node, authorized=False)
+        assert_equal(template["pohw_idena_authorization_required"], True)
+        assert_equal(template["pohw_idena_authorization_activation_id"], ACTIVATION_ID)
+        assert_equal(template["pohw_idena_authorization_policy_hash"], POLICY_HASH)
+        assert_equal(template["pohw_idena_authorization_root"], AUTHORIZATION_ROOT)
+        assert_equal(template["pohw_idena_authorization_expiry_height"], EXPIRY_HEIGHT)
+        assert_equal(template["pohw_idena_authorization_expiry_mtp"], 4102444800)
+        assert_equal(
+            template["pohw_idena_authorization_parent_mtp"],
+            node.getblockheader(parent_hash)["mediantime"],
+        )
+
+        self.log.info("A competing activation parent is rejected by ConnectBlock")
+        alternate_parent = create_block(
+            int(predecessor_hash, 16),
+            create_coinbase(ACTIVATION_HEIGHT - 1),
+            predecessor_time + 2,
+        )
+        alternate_parent.solve()
+        node.invalidateblock(parent_hash)
+        assert_equal(node.getblockcount(), ACTIVATION_HEIGHT - 2)
+        assert_equal(
+            node.submitblock(alternate_parent.serialize().hex()),
+            "bad-pohw-idena-auth-parent",
+        )
+        node.reconsiderblock(parent_hash)
+        assert_equal(node.getbestblockhash(), parent_hash)
+
+        self.log.info("Missing and duplicate authorizations fail through submitblock")
+        missing, _ = candidate_block(node, authorized=False)
+        assert_equal(
+            node.submitblock(missing.serialize().hex()),
+            "bad-pohw-idena-auth-count",
+        )
+
+        duplicate, _ = candidate_block(node, authorized=True)
+        duplicate.vtx[0].vout.append(duplicate.vtx[0].vout[-1])
+        duplicate.hashMerkleRoot = duplicate.calc_merkle_root()
+        duplicate.solve()
+        assert_equal(
+            node.submitblock(duplicate.serialize().hex()),
+            "bad-pohw-idena-auth-count",
+        )
+
+        self.log.info("A valid signed P2IA1 block advances the active chain")
+        authorized, _ = candidate_block(node, authorized=True)
+        assert_equal(node.submitblock(authorized.serialize().hex()), None)
+        assert_equal(node.getblockcount(), ACTIVATION_HEIGHT)
+
+
+if __name__ == "__main__":
+    PoHWIdentityAuthorizationTest(__file__).main()
