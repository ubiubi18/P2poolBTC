      "bootstrap_pow_limit": "7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
      "bootstrap_pow_limit_bits": "207fffff",
      "bootstrap_adjustment_min_factor_numerator": 1,
      "bootstrap_adjustment_min_factor_denominator": 4,
