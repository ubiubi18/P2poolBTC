      "rule": "inherited-input-requires-fork-only-marker-v2",
      "required": true,
      "marker_activation_height": 958018,
      "marker_script_hex": "5150",
      "description": "The first fork block is an immutable consensus checkpoint. Every transaction at or after the marker activation height with an inherited input must also consume an activated zero-value coinbase output carrying the exact fork-only replay marker. The marker executes OP_RESERVED and is invalid on Bitcoin mainnet even if an outpoint collides.",
