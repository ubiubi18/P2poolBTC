{
  "name": "idena-snapshot-registry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "asc assembly/index.ts --target release",
    "build:smoke": "asc assembly/smoke_test.ts --target release --outFile build/snapshot-registry-smoke.wasm --textFile build/snapshot-registry-smoke.wat",
    "check:abi": "pnpm run build && node scripts/check-release-abi.mjs",
    "test": "pnpm run build:smoke && node scripts/smoke-test.mjs && pnpm run check:abi"
  },
  "devDependencies": {
    "assemblyscript": "^0.27.35"
  }
}
