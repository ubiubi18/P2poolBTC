{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/RevertProposalV1.schema.json",
  "title": "RevertProposalV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "executionId", "currentCanonicalCid", "replacementCanonicalCid", "reasonCid", "evidenceCid", "affectedRepositories", "rollbackInstructionsCid", "compatibilityChecksCid", "expeditedRecovery"],
  "properties": {
    "schemaVersion": {"const": 1},
    "executionId": {"type": "string", "pattern": "^exec-[0-9a-f]{24}$"},
    "currentCanonicalCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "replacementCanonicalCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "reasonCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "evidenceCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "affectedRepositories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,80}$"}},
    "rollbackInstructionsCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "compatibilityChecksCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "expeditedRecovery": {"type": "boolean"}
  }
}
