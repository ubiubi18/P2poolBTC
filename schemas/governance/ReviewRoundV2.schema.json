{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/ReviewRoundV2.schema.json",
  "title": "ReviewRoundV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewRoundId",
    "state",
    "parentCid",
    "candidateCid",
    "patchCid",
    "scopeEvidenceCid",
    "pinsetCid",
    "pinsetCount",
    "opener",
    "openedBlock",
    "endBlock",
    "claimDeadline",
    "proposalId",
    "agentReviewRoot",
    "buildAttestationRoot",
    "dataAvailabilityRoot",
    "reviewAttestations",
    "buildAttestations",
    "availabilityAttestations",
    "validReviews",
    "reviewModelFamilies",
    "reviewRuntimeGroups",
    "reviewOwners",
    "unresolvedCriticalFindings",
    "criticalFindingWaiverCid",
    "builders",
    "builderPlatforms",
    "builderConflicts",
    "availabilityOwners",
    "artifactDigest",
    "bond",
    "refundableBond"
  ],
  "properties": {
    "schemaVersion": {"const": 2},
    "reviewRoundId": {"$ref": "common.schema.json#/$defs/Sha256"},
    "state": {"enum": ["Open", "AvailabilityOpen", "Frozen", "Claimed", "Expired"]},
    "parentCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "candidateCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "patchCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "scopeEvidenceCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "pinsetCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "pinsetCount": {"type": "integer", "minimum": 1, "maximum": 4096},
    "opener": {"$ref": "common.schema.json#/$defs/Address"},
    "openedBlock": {"type": "integer", "minimum": 0},
    "endBlock": {"type": "integer", "minimum": 0},
    "claimDeadline": {"type": "integer", "minimum": 0},
    "proposalId": {"anyOf": [{"$ref": "common.schema.json#/$defs/Sha256"}, {"type": "null"}]},
    "agentReviewRoot": {"anyOf": [{"$ref": "common.schema.json#/$defs/Sha256"}, {"type": "null"}]},
    "buildAttestationRoot": {"anyOf": [{"$ref": "common.schema.json#/$defs/Sha256"}, {"type": "null"}]},
    "dataAvailabilityRoot": {"anyOf": [{"$ref": "common.schema.json#/$defs/Sha256"}, {"type": "null"}]},
    "reviewAttestations": {"type": "integer", "minimum": 0, "maximum": 256},
    "buildAttestations": {"type": "integer", "minimum": 0, "maximum": 256},
    "availabilityAttestations": {"type": "integer", "minimum": 0, "maximum": 256},
    "validReviews": {"type": "integer", "minimum": 0, "maximum": 256},
    "reviewModelFamilies": {"type": "integer", "minimum": 0, "maximum": 256},
    "reviewRuntimeGroups": {"type": "integer", "minimum": 0, "maximum": 256},
    "reviewOwners": {"type": "integer", "minimum": 0, "maximum": 256},
    "unresolvedCriticalFindings": {"type": "integer", "minimum": 0},
    "criticalFindingWaiverCid": {"anyOf": [{"$ref": "common.schema.json#/$defs/DagCborCid"}, {"type": "null"}]},
    "builders": {"type": "integer", "minimum": 0, "maximum": 256},
    "builderPlatforms": {"type": "integer", "minimum": 0, "maximum": 256},
    "builderConflicts": {"type": "integer", "minimum": 0, "maximum": 256},
    "availabilityOwners": {"type": "integer", "minimum": 0, "maximum": 256},
    "artifactDigest": {"anyOf": [{"$ref": "common.schema.json#/$defs/Sha256"}, {"type": "null"}]},
    "bond": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "refundableBond": {"$ref": "common.schema.json#/$defs/AtomicAmount"}
  }
}
