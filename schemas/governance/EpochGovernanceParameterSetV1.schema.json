{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/EpochGovernanceParameterSetV1.schema.json",
  "title": "EpochGovernanceParameterSetV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "stakeQuantumAtoms", "minimumActiveStakeAtoms", "identityMath", "lifecycle", "contractBondPolicy", "contractResourceLimits", "normalProposalBondAtoms", "criticalProposalBondAtoms", "rejectedBondBurnBps", "rejectedBondTreasuryBps", "noQuorumFeeAtoms", "cancellationFeeAtoms", "maximumProposalsPerEpoch", "schedule", "normalLimits", "criticalLimits", "normal", "critical"],
  "properties": {
    "schemaVersion": {"const": 1},
    "stakeQuantumAtoms": {"const": "1000000000000"},
    "minimumActiveStakeAtoms": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "identityMath": {"$ref": "#/$defs/identityMath"},
    "lifecycle": {"$ref": "#/$defs/lifecycle"},
    "contractBondPolicy": {"$ref": "#/$defs/contractBondPolicy"},
    "contractResourceLimits": {"$ref": "#/$defs/contractResourceLimits"},
    "normalProposalBondAtoms": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "criticalProposalBondAtoms": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "rejectedBondBurnBps": {"type": "integer", "minimum": 0, "maximum": 10000},
    "rejectedBondTreasuryBps": {"type": "integer", "minimum": 0, "maximum": 10000},
    "noQuorumFeeAtoms": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "cancellationFeeAtoms": {"$ref": "common.schema.json#/$defs/AtomicAmount"},
    "maximumProposalsPerEpoch": {"type": "integer", "minimum": 1, "maximum": 4096},
    "schedule": {"$ref": "#/$defs/schedule"},
    "normalLimits": {"$ref": "#/$defs/limits"},
    "criticalLimits": {"$ref": "#/$defs/limits"},
    "normal": {"$ref": "#/$defs/gates"},
    "critical": {"$ref": "#/$defs/gates"}
  },
  "$defs": {
    "identityMath": {
      "type": "object", "additionalProperties": false,
      "required": ["idnaAtomsPerUnit", "statusBps", "flipPriorReported", "flipPriorTotal", "flipTrustFloorBps", "flipTrustCeilingBps", "flipPenaltyScale"],
      "properties": {
        "idnaAtomsPerUnit": {"const": "1000000000000000000"},
        "statusBps": {"type": "object", "additionalProperties": false, "required": ["Human", "Verified", "Newbie"], "properties": {"Human": {"const": 10000}, "Verified": {"const": 8500}, "Newbie": {"const": 7000}}},
        "flipPriorReported": {"const": 1},
        "flipPriorTotal": {"const": 20},
        "flipTrustFloorBps": {"const": 4000},
        "flipTrustCeilingBps": {"const": 10000},
        "flipPenaltyScale": {"const": 15000}
      }
    },
    "lifecycle": {
      "type": "object", "additionalProperties": false,
      "required": ["reviewPeriodBlocks", "votingPeriodBlocks", "challengePeriodBlocks", "timelockBlocks", "executionWindowBlocks", "unbondingDelayEpochs", "minimumIdentityMetricsAttestations"],
      "properties": {
        "reviewPeriodBlocks": {"const": 40}, "votingPeriodBlocks": {"const": 120},
        "challengePeriodBlocks": {"const": 60}, "timelockBlocks": {"const": 60},
        "executionWindowBlocks": {"const": 600}, "unbondingDelayEpochs": {"const": 4},
        "minimumIdentityMetricsAttestations": {"const": 3}
      }
    },
    "contractBondPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["minimumReviewerBondAtoms", "minimumBuilderBondAtoms", "minimumDataAvailabilityBondAtoms", "staleProcessingFeeAtoms", "rejectedProposalReturnBps", "expiredReviewRoundReturnBps", "expiredProposalReturnBps", "successfulChallengeProposerReturnBps", "unavailableAttestationSlashBps", "fraudulentActorStakeSlashBps"],
      "properties": {
        "minimumReviewerBondAtoms": {"const": "1000000000000000000"},
        "minimumBuilderBondAtoms": {"const": "1000000000000000000"},
        "minimumDataAvailabilityBondAtoms": {"const": "1000000000000000000"},
        "staleProcessingFeeAtoms": {"const": "100000000000000000"},
        "rejectedProposalReturnBps": {"const": 9000}, "expiredReviewRoundReturnBps": {"const": 7500},
        "expiredProposalReturnBps": {"const": 7500}, "successfulChallengeProposerReturnBps": {"const": 5000},
        "unavailableAttestationSlashBps": {"const": 5000}, "fraudulentActorStakeSlashBps": {"const": 500}
      }
    },
    "contractResourceLimits": {
      "type": "object", "additionalProperties": false,
      "required": ["maxStakeHistory", "maxPortableArtifactSize", "maxCommittedAttestations", "maxAttestationsPerOwnerPerClass", "maxRequiredAvailabilityCids", "maxScopeProofBytes", "maxScopeFilesPerRepository", "maxScopeSourceFileBytes", "maxScopeSourceTreeBytes"],
      "properties": {
        "maxStakeHistory": {"const": 256}, "maxPortableArtifactSize": {"const": 9007199254740991},
        "maxCommittedAttestations": {"const": 256}, "maxAttestationsPerOwnerPerClass": {"const": 2},
        "maxRequiredAvailabilityCids": {"const": 4096}, "maxScopeProofBytes": {"const": 600000},
        "maxScopeFilesPerRepository": {"const": 2048}, "maxScopeSourceFileBytes": {"const": 268435456},
        "maxScopeSourceTreeBytes": {"const": 2147483648}
      }
    },
    "schedule": {
      "type": "object", "additionalProperties": false,
      "required": ["proposalCutoff", "commitStart", "commitEnd", "revealEnd", "normalGraceBlocks", "criticalGraceBlocks", "executionWindowBlocks", "observationWindowBlocks"],
      "properties": {
        "proposalCutoff": {"type": "integer", "minimum": 1},
        "commitStart": {"type": "integer", "minimum": 1},
        "commitEnd": {"type": "integer", "minimum": 1},
        "revealEnd": {"type": "integer", "minimum": 1},
        "normalGraceBlocks": {"type": "integer", "minimum": 1},
        "criticalGraceBlocks": {"type": "integer", "minimum": 1},
        "executionWindowBlocks": {"type": "integer", "minimum": 1},
        "observationWindowBlocks": {"type": "integer", "minimum": 1}
      }
    },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["maxAffectedRepositories", "maxChangedFiles", "maxPatchBytes", "maxSourcePackageBytes", "maxDescriptionBytes", "maxMigrationOperations"],
      "properties": {
        "maxAffectedRepositories": {"type": "integer", "minimum": 1},
        "maxChangedFiles": {"type": "integer", "minimum": 1},
        "maxPatchBytes": {"type": "integer", "minimum": 1},
        "maxSourcePackageBytes": {"type": "integer", "minimum": 1},
        "maxDescriptionBytes": {"type": "integer", "minimum": 1},
        "maxMigrationOperations": {"type": "integer", "minimum": 0}
      }
    },
    "gates": {
      "type": "object", "additionalProperties": false,
      "required": ["turnoutQuorumBps", "yesThresholdBps", "minimumParticipatingIdentities", "minimumYesIdentities", "minimumVerifiedOrHumanYes", "minimumAiAttestations", "minimumAiIndependenceGroups", "minimumAiFamilies", "minimumAiOwnerIdentities", "criticalFindingOwnerThreshold", "minimumBuilders", "minimumBuilderPlatforms", "minimumDataAvailabilityProviders", "requireMatchingBuildDigests"],
      "properties": {
        "turnoutQuorumBps": {"type": "integer", "minimum": 1, "maximum": 10000},
        "yesThresholdBps": {"type": "integer", "minimum": 1, "maximum": 10000},
        "minimumParticipatingIdentities": {"type": "integer", "minimum": 1},
        "minimumYesIdentities": {"type": "integer", "minimum": 1},
        "minimumVerifiedOrHumanYes": {"type": "integer", "minimum": 0},
        "minimumAiAttestations": {"type": "integer", "minimum": 1},
        "minimumAiIndependenceGroups": {"type": "integer", "minimum": 1},
        "minimumAiFamilies": {"type": "integer", "minimum": 1},
        "minimumAiOwnerIdentities": {"type": "integer", "minimum": 1},
        "criticalFindingOwnerThreshold": {"type": "integer", "minimum": 2},
        "minimumBuilders": {"type": "integer", "minimum": 1},
        "minimumBuilderPlatforms": {"type": "integer", "minimum": 1},
        "minimumDataAvailabilityProviders": {"type": "integer", "minimum": 1},
        "requireMatchingBuildDigests": {"type": "boolean"}
      }
    }
  }
}
