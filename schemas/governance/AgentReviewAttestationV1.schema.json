{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://pohw.example/schemas/governance/AgentReviewAttestationV1.schema.json",
  "title":"AgentReviewAttestationV1 canonical payload",
  "description":"The attestation CID is derived from this payload and appears only in the deterministic human envelope, avoiding a self-referential hash.",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","parentEcosystemCid","candidateEcosystemCid","patchCid","affectedRepositories","modelIdentifier","modelRevision","providerOrRuntimeIdentifier","modelFamily","agentPolicyCid","systemPromptPolicyCid","toolVersions","commandsExecuted","testResultsCid","testsPassed","staticAnalysisResultsCid","dependencyFindingsCid","securityFindings","unresolvedCriticalFindings","verdict","ownerIdenaAddress","reviewerBondAtoms","creationBlockOrTimestamp","authentication"],
  "properties":{
    "schemaVersion":{"const":1},
    "parentEcosystemCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "candidateEcosystemCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "patchCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "affectedRepositories":{"type":"array","minItems":1,"maxItems":64,"items":{"$ref":"common.schema.json#/$defs/AttestedRepositoryCid"}},
    "modelIdentifier":{"type":"string","minLength":1,"maxLength":160},
    "modelRevision":{"type":["string","null"],"minLength":1,"maxLength":160},
    "providerOrRuntimeIdentifier":{"type":"string","minLength":1,"maxLength":160},
    "modelFamily":{"type":"string","pattern":"^[a-z0-9._-]{1,64}$"},
    "agentPolicyCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "systemPromptPolicyCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "toolVersions":{"type":"object","minProperties":1,"maxProperties":256,"propertyNames":{"pattern":"^[A-Za-z0-9._-]{1,80}$"},"additionalProperties":{"type":"string","minLength":1,"maxLength":160}},
    "commandsExecuted":{"type":"array","minItems":1,"maxItems":2000,"items":{"$ref":"common.schema.json#/$defs/CommandExecution"}},
    "testResultsCid":{"$ref":"common.schema.json#/$defs/RawCid"},
    "testsPassed":{"type":"boolean"},
    "staticAnalysisResultsCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "dependencyFindingsCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "securityFindings":{"type":"array","maxItems":10000,"items":{
      "type":"object","additionalProperties":false,
      "required":["severity","summary","evidenceCid","resolved"],
      "properties":{
        "severity":{"enum":["info","low","medium","high","critical"]},
        "summary":{"type":"string","minLength":1,"maxLength":4096},
        "evidenceCid":{"anyOf":[{"$ref":"common.schema.json#/$defs/ContentCid"},{"type":"null"}]},
        "resolved":{"type":"boolean"}
      },
      "allOf":[{
        "if":{"properties":{"severity":{"const":"critical"},"resolved":{"const":false}},"required":["severity","resolved"]},
        "then":{"properties":{"evidenceCid":{"$ref":"common.schema.json#/$defs/ContentCid"}}}
      }]
    }},
    "unresolvedCriticalFindings":{"type":"integer","minimum":0,"maximum":4294967295},
    "verdict":{"enum":["approve","reject","abstain"]},
    "ownerIdenaAddress":{"$ref":"common.schema.json#/$defs/Address"},
    "reviewerBondAtoms":{"$ref":"common.schema.json#/$defs/AtomicAmount"},
    "creationBlockOrTimestamp":{"type":"integer","minimum":0},
    "authentication":{"enum":["on-chain-submitter","detached-idena-signature-v1"],"description":"Authentication intent. Detached signature use additionally requires an AttestationAuthenticationV1 proof."}
  }
}
