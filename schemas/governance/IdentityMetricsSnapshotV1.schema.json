{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://pohw.example/schemas/governance/IdentityMetricsSnapshotV1.schema.json",
  "title":"IdentityMetricsSnapshotV1",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","sourceEpoch","sourceBlockHeight","sourceBlockHash","replayStartHeight","replayCommitment","sourceBlockHashes","leaves","merkleRoot"],
  "properties":{
    "schemaVersion":{"const":1},
    "sourceEpoch":{"type":"integer","minimum":0,"maximum":65535},
    "sourceBlockHeight":{"type":"integer","minimum":0},
    "sourceBlockHash":{"$ref":"common.schema.json#/$defs/Sha256"},
    "replayStartHeight":{"type":"integer","minimum":0},
    "replayCommitment":{"$ref":"common.schema.json#/$defs/Sha256"},
    "sourceBlockHashes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"$ref":"common.schema.json#/$defs/Sha256"}},
    "leaves":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["address","identityState","totalFinalizedAuthoredFlips","totalConsensusReportedAuthoredFlips","flipTrustBps","sourceEpoch","sourceBlockHeight","sourceBlockHash"],"properties":{
      "address":{"$ref":"common.schema.json#/$defs/Address"},
      "identityState":{"$ref":"common.schema.json#/$defs/IdentityState"},
      "totalFinalizedAuthoredFlips":{"type":"integer","minimum":0},
      "totalConsensusReportedAuthoredFlips":{"type":"integer","minimum":0},
      "flipTrustBps":{"type":"integer","minimum":4000,"maximum":10000},
      "sourceEpoch":{"type":"integer","minimum":0,"maximum":65535},
      "sourceBlockHeight":{"type":"integer","minimum":0},
      "sourceBlockHash":{"$ref":"common.schema.json#/$defs/Sha256"}
    }}},
    "merkleRoot":{"$ref":"common.schema.json#/$defs/Sha256"}
  }
}
