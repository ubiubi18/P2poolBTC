{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://pohw.example/schemas/governance/ChangeProposalV1.schema.json",
  "title":"ChangeProposalV1 deterministic human envelope",
  "description":"proposalId, proposalCid, proposalSha256, and carSha256 are derived envelope fields. The canonical DAG-CBOR payload consists of the remaining fields.",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","proposalId","proposalCid","proposalSha256","carSha256","governanceParameterSetCid","parentCanonicalEcosystemCid","candidateEcosystemCid","affectedRepositories","changedFileCount","patchBytes","sourcePackageBytes","descriptionBytes","migrationOperationCount","baseSourceCids","candidateSourceCids","patchCid","reviewRoundId","proposerAddress","proposalBondAtoms","riskClass","rationaleCid","migrationNotesCid","testPlanCid","rollbackManifestCid","rollbackInstructionsCid","releaseManifestCid","criticalFindingWaiverCid","agentReviewRoot","buildAttestationRoot","dataAvailabilityRoot","creationBlock","creationEpoch","stakingEpoch","identityMetricsEpoch","candidateIdentityMetricsRoot","candidateIdentityMetricsEpoch","votingStart","votingEnd","challengeEnd"],
  "properties":{
    "schemaVersion":{"const":1},
    "proposalId":{"$ref":"common.schema.json#/$defs/Sha256"},
    "proposalCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "proposalSha256":{"$ref":"common.schema.json#/$defs/Sha256"},
    "carSha256":{"$ref":"common.schema.json#/$defs/Sha256"},
    "governanceParameterSetCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "parentCanonicalEcosystemCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "candidateEcosystemCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "affectedRepositories":{"type":"array","minItems":1,"maxItems":16,"uniqueItems":true,"items":{"type":"string","pattern":"^[A-Za-z0-9._-]{1,80}$"}},
    "changedFileCount":{"type":"integer","minimum":1,"maximum":1024},
    "patchBytes":{"type":"integer","minimum":1,"maximum":16777216},
    "sourcePackageBytes":{"type":"integer","minimum":1,"maximum":1073741824},
    "descriptionBytes":{"type":"integer","minimum":1,"maximum":65536},
    "migrationOperationCount":{"type":"integer","minimum":0,"maximum":64},
    "baseSourceCids":{"type":"object","minProperties":1,"maxProperties":16,"additionalProperties":{"$ref":"common.schema.json#/$defs/DagCborCid"}},
    "candidateSourceCids":{"type":"object","minProperties":1,"maxProperties":16,"additionalProperties":{"$ref":"common.schema.json#/$defs/DagCborCid"}},
    "patchCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "reviewRoundId":{"$ref":"common.schema.json#/$defs/Sha256"},
    "proposerAddress":{"$ref":"common.schema.json#/$defs/Address"},
    "proposalBondAtoms":{"$ref":"common.schema.json#/$defs/AtomicAmount"},
    "riskClass":{"$ref":"common.schema.json#/$defs/RiskClass"},
    "rationaleCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "migrationNotesCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "testPlanCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "rollbackManifestCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "rollbackInstructionsCid":{"$ref":"common.schema.json#/$defs/ContentCid"},
    "releaseManifestCid":{"anyOf":[{"$ref":"common.schema.json#/$defs/DagCborCid"},{"type":"null"}]},
    "criticalFindingWaiverCid":{"anyOf":[{"$ref":"common.schema.json#/$defs/DagCborCid"},{"type":"null"}]},
    "agentReviewRoot":{"$ref":"common.schema.json#/$defs/Sha256"},
    "buildAttestationRoot":{"$ref":"common.schema.json#/$defs/Sha256"},
    "dataAvailabilityRoot":{"$ref":"common.schema.json#/$defs/Sha256"},
    "creationBlock":{"type":"integer","minimum":0},
    "creationEpoch":{"type":"integer","minimum":0,"maximum":65535},
    "stakingEpoch":{"type":"integer","minimum":0,"maximum":65535},
    "identityMetricsEpoch":{"type":"integer","minimum":0,"maximum":65535},
    "candidateIdentityMetricsRoot":{"anyOf":[{"$ref":"common.schema.json#/$defs/Sha256"},{"type":"null"}]},
    "candidateIdentityMetricsEpoch":{"type":["integer","null"],"minimum":0,"maximum":65535},
    "votingStart":{"type":"integer","minimum":0},
    "votingEnd":{"type":"integer","minimum":0},
    "challengeEnd":{"type":"integer","minimum":0}
  }
}
