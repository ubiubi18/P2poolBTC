{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/MigrationRehearsalAttestationV1.schema.json",
  "title": "MigrationRehearsalAttestationV1 canonical payload",
  "description": "One operator's authenticated observation of a deployed testnet migration, canonical-CID replacement, and governed rollback. Private endpoints, credentials, keys, and raw logs are forbidden; only content CIDs are recorded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "parentEcosystemCid",
    "candidateEcosystemCid",
    "scopeEvidenceCid",
    "networkId",
    "governanceContractAddress",
    "governanceContractCodeCid",
    "deploymentTxHash",
    "deploymentBlock",
    "executionProposalId",
    "executionTxHash",
    "executionBlock",
    "observedCandidateEcosystemCid",
    "rollbackProposalId",
    "rollbackTxHash",
    "rollbackBlock",
    "observedRollbackEcosystemCid",
    "stateSnapshotCid",
    "eventLogCid",
    "commandLogCid",
    "legacyCompatibilityReportCid",
    "governanceDisabledReportCid",
    "rehearsalDigest",
    "testsPassed",
    "operatorIdentity",
    "runtimeFamily",
    "architecture",
    "creationBlockOrTimestamp",
    "authentication"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "parentEcosystemCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "candidateEcosystemCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "scopeEvidenceCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "networkId": {"type": "string", "pattern": "^[a-z0-9._-]{1,80}$"},
    "governanceContractAddress": {"$ref": "common.schema.json#/$defs/Address"},
    "governanceContractCodeCid": {"$ref": "common.schema.json#/$defs/RawCid"},
    "deploymentTxHash": {"$ref": "common.schema.json#/$defs/Sha256"},
    "deploymentBlock": {"type": "integer", "minimum": 0},
    "executionProposalId": {"$ref": "common.schema.json#/$defs/Sha256"},
    "executionTxHash": {"$ref": "common.schema.json#/$defs/Sha256"},
    "executionBlock": {"type": "integer", "minimum": 0},
    "observedCandidateEcosystemCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "rollbackProposalId": {"$ref": "common.schema.json#/$defs/Sha256"},
    "rollbackTxHash": {"$ref": "common.schema.json#/$defs/Sha256"},
    "rollbackBlock": {"type": "integer", "minimum": 0},
    "observedRollbackEcosystemCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "stateSnapshotCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "eventLogCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "commandLogCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "legacyCompatibilityReportCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "governanceDisabledReportCid": {"$ref": "common.schema.json#/$defs/ContentCid"},
    "rehearsalDigest": {"$ref": "common.schema.json#/$defs/Sha256"},
    "testsPassed": {"type": "boolean"},
    "operatorIdentity": {"$ref": "common.schema.json#/$defs/Address"},
    "runtimeFamily": {"type": "string", "pattern": "^[a-z0-9._-]{1,31}$"},
    "architecture": {"type": "string", "pattern": "^[a-z0-9._-]{1,31}$"},
    "creationBlockOrTimestamp": {"type": "integer", "minimum": 0},
    "authentication": {
      "enum": ["on-chain-submitter", "detached-idena-signature-v1"],
      "description": "Authentication intent only. Deployment readiness also requires an AttestationAuthenticationV1 proof bound to the exact payload CID."
    }
  }
}
