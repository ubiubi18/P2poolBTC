{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/DeploymentReadinessInputV1.schema.json",
  "title": "DeploymentReadinessInputV1 local evidence paths",
  "description": "Operational input only. Paths are never part of a canonical governance object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scopeCar",
    "buildAttestations",
    "dataAvailabilityAttestations",
    "externalAuditAttestations",
    "requiredAvailabilityThroughBlock"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "scopeCar": {"type": "string", "minLength": 1},
    "buildAttestations": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/AuthenticatedAttestationInput"}
    },
    "dataAvailabilityAttestations": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/AuthenticatedAttestationInput"}
    },
    "externalAuditAttestations": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/AuthenticatedAttestationInput"}
    },
    "requiredAvailabilityThroughBlock": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "AuthenticatedAttestationInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["car", "authentication"],
      "properties": {
        "car": {"type": "string", "minLength": 1},
        "authentication": {"type": "string", "minLength": 1}
      }
    }
  }
}
