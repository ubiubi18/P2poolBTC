{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/AttestationAuthenticationV1.schema.json",
  "title": "AttestationAuthenticationV1 detached authentication envelope",
  "description": "Binds an address proof to an exact canonical attestation kind, CID/content digest, candidate ecosystem CID, and role identity without introducing a self-referential attestation CID.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attestationKind",
    "attestationCid",
    "attestationSha256",
    "candidateEcosystemCid",
    "identity",
    "bindingSha256",
    "proof"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "attestationKind": {"enum": ["agent_review_v1", "build_attestation_v1", "data_availability_v1", "external_audit_v1"]},
    "attestationCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "attestationSha256": {"$ref": "common.schema.json#/$defs/Sha256"},
    "candidateEcosystemCid": {"$ref": "common.schema.json#/$defs/DagCborCid"},
    "identity": {"type": "string", "pattern": "^0x[0-9a-f]{40}$"},
    "bindingSha256": {"$ref": "common.schema.json#/$defs/Sha256"},
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "signatureHex"],
      "properties": {
        "method": {"const": "idena-signature-v1"},
        "signatureHex": {"type": "string", "pattern": "^(0x)?[0-9a-fA-F]{130}$"}
      }
    }
  }
}
