{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.example/schemas/governance/common.schema.json",
  "$defs": {
    "DagCborCid": {"type":"string","pattern":"^bafyrei[a-z2-7]{52}$"},
    "RawCid": {"type":"string","pattern":"^bafkrei[a-z2-7]{52}$"},
    "ContentCid": {
      "anyOf":[
        {"$ref":"#/$defs/DagCborCid"},
        {"$ref":"#/$defs/RawCid"}
      ]
    },
    "Cid": {"$ref":"#/$defs/ContentCid"},
    "Sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "Address": {"type":"string","pattern":"^0x[0-9a-fA-F]{40}$"},
    "AtomicAmount": {"type":"string","pattern":"^(0|[1-9][0-9]{0,38})$"},
    "PortableArtifactName": {"type":"string","pattern":"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "RiskClass": {"enum":["normal","critical","consensus","migration"]},
    "IdentityState": {"enum":["Human","Verified","Newbie"]},
    "RepositoryCid": {
      "type":"object",
      "additionalProperties":false,
      "required":["name","sourceTreeCid"],
      "properties":{"name":{"type":"string","pattern":"^[A-Za-z0-9._-]{1,80}$"},"sourceTreeCid":{"$ref":"#/$defs/DagCborCid"}}
    },
    "AttestedRepositoryCid": {
      "type":"object",
      "additionalProperties":false,
      "required":["repository","cid"],
      "properties":{
        "repository":{"type":"string","pattern":"^[A-Za-z0-9._-]{1,80}$"},
        "cid":{"$ref":"#/$defs/DagCborCid"}
      }
    },
    "CommandExecution": {
      "type":"object",
      "additionalProperties":false,
      "required":["command","exitCode","stdoutSha256","stderrSha256"],
      "properties":{
        "command":{"type":"string","minLength":1,"maxLength":8192},
        "exitCode":{"type":"integer","minimum":-2147483648,"maximum":2147483647},
        "stdoutSha256":{"$ref":"#/$defs/Sha256"},
        "stderrSha256":{"$ref":"#/$defs/Sha256"}
      }
    },
    "Artifact": {
      "type":"object",
      "additionalProperties":false,
      "required":["name","cid","sha256","size"],
      "properties":{
        "name":{"$ref":"#/$defs/PortableArtifactName"},
        "cid":{"$ref":"#/$defs/RawCid"},
        "sha256":{"$ref":"#/$defs/Sha256"},
        "size":{"type":"integer","minimum":0,"maximum":9007199254740991}
      }
    }
  }
}
