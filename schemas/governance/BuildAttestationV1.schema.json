{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://pohw.example/schemas/governance/BuildAttestationV1.schema.json",
  "title":"BuildAttestationV1 canonical payload",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","candidateEcosystemCid","sourceCids","toolchainCid","builderIdentity","runtimeFamily","architecture","commands","testResultsCid","testsPassed","sbomCid","artifacts","coreArtifactDigest","builderBondAtoms","creationBlockOrTimestamp","authentication"],
  "properties":{
    "schemaVersion":{"const":1},
    "candidateEcosystemCid":{"$ref":"common.schema.json#/$defs/DagCborCid"},
    "sourceCids":{"type":"array","minItems":1,"maxItems":64,"items":{"$ref":"common.schema.json#/$defs/AttestedRepositoryCid"}},
    "toolchainCid":{"$ref":"common.schema.json#/$defs/DagCborCid","description":"Canonical DAG-CBOR CIDv1/SHA2-256 of the complete toolchain lock map."},
    "builderIdentity":{"$ref":"common.schema.json#/$defs/Address"},
    "runtimeFamily":{"type":"string","pattern":"^[a-z0-9._-]{1,31}$"},
    "architecture":{"type":"string","pattern":"^[a-z0-9._-]{1,31}$"},
    "commands":{"type":"array","minItems":1,"maxItems":2000,"items":{"$ref":"common.schema.json#/$defs/CommandExecution"}},
    "testResultsCid":{"$ref":"common.schema.json#/$defs/RawCid","description":"Raw CIDv1/SHA2-256."},
    "testsPassed":{"type":"boolean"},
    "sbomCid":{"$ref":"common.schema.json#/$defs/RawCid","description":"Raw CIDv1/SHA2-256."},
    "artifacts":{"type":"array","minItems":1,"maxItems":4096,"items":{"$ref":"#/$defs/BuildArtifact"}},
    "coreArtifactDigest":{"$ref":"common.schema.json#/$defs/Sha256","description":"Domain-separated digest of every artifact whose core flag is true."},
    "builderBondAtoms":{"$ref":"common.schema.json#/$defs/AtomicAmount"},
    "creationBlockOrTimestamp":{"type":"integer","minimum":0},
    "authentication":{"const":"on-chain-submitter"}
  },
  "$defs":{
    "BuildArtifact":{
      "type":"object",
      "additionalProperties":false,
      "required":["name","cid","sha256","size","core"],
      "properties":{
        "name":{"$ref":"common.schema.json#/$defs/PortableArtifactName"},
        "cid":{"$ref":"common.schema.json#/$defs/RawCid","description":"Raw CIDv1/SHA2-256."},
        "sha256":{"$ref":"common.schema.json#/$defs/Sha256"},
        "size":{"type":"integer","minimum":0,"maximum":9007199254740991},
        "core":{"type":"boolean"}
      }
    }
  }
}
