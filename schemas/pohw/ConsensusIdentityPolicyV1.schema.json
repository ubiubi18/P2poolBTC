{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://p2poolbtc.invalid/schemas/pohw/ConsensusIdentityPolicyV1.schema.json",
  "title": "ConsensusIdentityPolicyV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "bitcoin_network",
    "bitcoin_fork_activation_id",
    "share_work_activation_id",
    "registry_contract_address",
    "idena_finalized_height",
    "idena_finalized_timestamp",
    "idena_finalized_block_hash",
    "idena_next_validation_timestamp",
    "authorization_root",
    "authorized_identity_count",
    "bitcoin_activation_height",
    "bitcoin_expiry_height",
    "bitcoin_expiry_mtp",
    "max_proof_depth",
    "require_share_work_commitment"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "experiment_id": { "const": "p2poolbtc-experiment-2" },
    "bitcoin_network": { "const": "pohw2" },
    "bitcoin_fork_activation_id": { "$ref": "#/$defs/hash" },
    "share_work_activation_id": { "$ref": "#/$defs/hash" },
    "registry_contract_address": { "$ref": "#/$defs/address" },
    "idena_finalized_height": { "type": "integer", "minimum": 1 },
    "idena_finalized_timestamp": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "idena_finalized_block_hash": { "$ref": "#/$defs/prefixedHash" },
    "idena_next_validation_timestamp": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "authorization_root": { "$ref": "#/$defs/hash" },
    "authorized_identity_count": { "type": "integer", "minimum": 1, "maximum": 65536 },
    "bitcoin_activation_height": { "type": "integer", "minimum": 1 },
    "bitcoin_expiry_height": { "type": "integer", "minimum": 1 },
    "bitcoin_expiry_mtp": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
    "max_proof_depth": { "type": "integer", "minimum": 0, "maximum": 16 },
    "require_share_work_commitment": { "const": true }
  },
  "allOf": [
    { "if": { "properties": { "authorized_identity_count": { "minimum": 2 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 1 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 3 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 2 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 5 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 3 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 9 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 4 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 17 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 5 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 33 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 6 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 65 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 7 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 129 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 8 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 257 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 9 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 513 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 10 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 1025 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 11 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 2049 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 12 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 4097 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 13 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 8193 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 14 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 16385 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 15 } } } },
    { "if": { "properties": { "authorized_identity_count": { "minimum": 32769 } } }, "then": { "properties": { "max_proof_depth": { "minimum": 16 } } } }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "prefixedHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-f]{40}$" }
  }
}
