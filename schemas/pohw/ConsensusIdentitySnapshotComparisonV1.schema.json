{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://p2poolbtc.invalid/schemas/pohw/ConsensusIdentitySnapshotComparisonV1.schema.json",
  "title": "ConsensusIdentitySnapshotComparisonV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "experiment_id",
    "registry_contract_address",
    "source_input_hash",
    "idena_finalized_height",
    "idena_finalized_block_hash",
    "idena_identity_root",
    "idena_finality_height",
    "idena_finality_block_hash",
    "finality_confirmations",
    "authorization_root",
    "authorized_identity_count",
    "verifier_sha256",
    "matching_capture_count",
    "minimum_matching_captures",
    "verification_sha256",
    "distinct_capture_files_verified",
    "identity_rows_assurance",
    "identity_rows_cryptographically_bound_to_root",
    "operator_independence_verified",
    "release_authorized",
    "next_gate"
  ],
  "properties": {
    "schema_version": { "const": "pohw-consensus-identity-snapshot-comparison/v1" },
    "status": { "const": "matching-snapshot-boundary-unattributed" },
    "experiment_id": { "const": "p2poolbtc-experiment-2" },
    "registry_contract_address": { "$ref": "#/$defs/address" },
    "source_input_hash": { "$ref": "#/$defs/hash" },
    "idena_finalized_height": { "$ref": "#/$defs/positiveInteger" },
    "idena_finalized_block_hash": { "$ref": "#/$defs/prefixedHash" },
    "idena_identity_root": { "$ref": "#/$defs/prefixedHash" },
    "idena_finality_height": { "$ref": "#/$defs/positiveInteger" },
    "idena_finality_block_hash": { "$ref": "#/$defs/prefixedHash" },
    "finality_confirmations": { "type": "integer", "minimum": 6, "maximum": 120 },
    "authorization_root": { "$ref": "#/$defs/hash" },
    "authorized_identity_count": { "type": "integer", "minimum": 1, "maximum": 48 },
    "verifier_sha256": { "$ref": "#/$defs/hash" },
    "matching_capture_count": { "type": "integer", "minimum": 3 },
    "minimum_matching_captures": { "type": "integer", "minimum": 3 },
    "verification_sha256": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/hash" }
    },
    "distinct_capture_files_verified": { "const": true },
    "identity_rows_assurance": { "const": "compatible-rpc-unproven" },
    "identity_rows_cryptographically_bound_to_root": { "const": false },
    "operator_independence_verified": { "const": false },
    "release_authorized": { "const": false },
    "next_gate": { "type": "string", "minLength": 1, "maxLength": 256 }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "prefixedHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-f]{40}$" },
    "positiveInteger": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
  }
}
