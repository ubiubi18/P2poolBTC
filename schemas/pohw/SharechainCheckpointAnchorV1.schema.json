{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pohw.invalid/schemas/pohw/SharechainCheckpointAnchorV1.schema.json",
  "title": "SharechainCheckpointAnchorV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_address",
    "experiment_id",
    "round",
    "share_tip_hash",
    "share_height",
    "cumulative_score",
    "parent_checkpoint_tip",
    "finalization_block",
    "finalization_block_hash",
    "finalization_epoch",
    "finalization_timestamp",
    "support_count",
    "registered_count",
    "registered_miners",
    "supporters"
  ],
  "properties": {
    "contract_address": {"type": "string", "pattern": "^0x[0-9a-f]{40}$"},
    "experiment_id": {"type": "string", "pattern": "^[a-z0-9._:/-]{1,64}$"},
    "round": {"type": "integer", "minimum": 1, "maximum": 4294967295},
    "share_tip_hash": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
    "share_height": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "cumulative_score": {"type": "string", "pattern": "^[1-9][0-9]{0,38}$"},
    "parent_checkpoint_tip": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "finalization_block": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "finalization_block_hash": {"type": "string", "pattern": "^0x[0-9a-f]{64}$"},
    "finalization_epoch": {"type": "integer", "minimum": 0, "maximum": 65535},
    "finalization_timestamp": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "support_count": {"type": "integer", "minimum": 1, "maximum": 48},
    "registered_count": {"type": "integer", "minimum": 1, "maximum": 48},
    "registered_miners": {
      "type": "array",
      "minItems": 1,
      "maxItems": 48,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9._-]{1,64}$"}
    },
    "supporters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 48,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9._-]{1,64}$"}
    }
  }
}
