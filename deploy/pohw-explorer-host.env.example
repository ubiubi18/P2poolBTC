# Public PoHW explorer profile for a dedicated host.
# Install as /etc/pohw/explorer.env (mode 0600) and replace explorer.example.com.
# Do not put RPC cookies, API keys, passwords, wallet data, or private keys here.

POHW_WORKDIR=/opt/p2pool
POHW_DATADIR=/var/lib/pohw-p2pool/sharechain
POHW_SNAPSHOT_DIR=/var/lib/pohw-p2pool/snapshots

POHW_FORK_ACTIVATION_MANIFEST=/var/lib/pohw-p2pool/fork-activation.json
POHW_EXPLORER_FORK_CHAIN_RPC_ADDR=127.0.0.1:40408
POHW_EXPLORER_BITCOIN_INDEX_URL=http://127.0.0.1:3002
POHW_EXPLORER_ALLOW_REMOTE_BITCOIN_INDEX=false

POHW_DASHBOARD_BIND_ADDR=127.0.0.1:40407
POHW_DASHBOARD_ALLOW_NON_LOOPBACK=false
POHW_DASHBOARD_API_TOKEN_FILE=/etc/pohw/dashboard-api.token
POHW_DASHBOARD_ALLOWED_ORIGINS=https://explorer.example.com,http://127.0.0.1:5176
POHW_EXPLORER_PUBLIC=true

POHW_DASHBOARD_UI_DIR=/opt/p2pool/ui/pohw-dashboard
POHW_DASHBOARD_UI_DIST_DIR=/opt/p2pool/ui/pohw-dashboard/dist
POHW_DASHBOARD_UI_BIND_HOST=127.0.0.1
POHW_DASHBOARD_UI_PORT=5176
POHW_DASHBOARD_UI_API_URL=/dashboard.json
POHW_EXPLORER_UI_API_BASE=/api/v1
POHW_DASHBOARD_UI_DEFAULT_VIEW=explorer
POHW_DASHBOARD_UI_PARTICIPANT_ENABLED=false
POHW_DASHBOARD_UI_CACHE_DIR=/var/lib/pohw-p2pool/dashboard-ui-cache
