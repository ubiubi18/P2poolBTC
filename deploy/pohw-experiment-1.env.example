# P2poolBTC Experiment 1 adapter profile. Do not add keys or RPC passwords.
# Bitcoin inherited spends are enabled, so never reuse a valuable mainnet key.
# Idena is live; this service consumes public snapshot/signature evidence only.
POHW_EXPERIMENT_NO_VALUE_ACK=I_UNDERSTAND_NO_VALUE
POHW_WORKDIR=/opt/p2pool
POHW_P2POOL_NODE_BIN=/usr/local/libexec/p2pool-experiment-1/p2pool-node
POHW_DATADIR=/srv/sharechain/pohw-experiment-1-511f8b0b
POHW_GOSSIP_NETWORK_ID=86dfc3ff2736717781cdf007727bfc6bc3ec56a87f27a1d09703885adca434d8
POHW_SNAPSHOT_DIR=/srv/sharechain/snapshots

POHW_MINER_ID=
POHW_IDENA_SNAPSHOT_ID=
POHW_IDENA_SNAPSHOT_PROOF_ROOT=
# Experiment 1 is fail-closed until the ownerless registry is explicitly
# deployed, independently verified, and activated. The blank policy below is
# intentional: this template must not start mining as shipped.
POHW_REQUIRE_IDENA_ANCHOR_POLICY=true
POHW_ADMIT_PEER_WORK_TEMPLATES=true
POHW_IDENA_ANCHOR_POLICY=
POHW_IDENA_RPC_ALLOW_REMOTE=false
POHW_MINER_REGISTRY_EXPERIMENT_ID=p2poolbtc-experiment-1
POHW_MINER_REGISTRY_ANCHOR_FILE=
IDENA_RPC_URL=http://127.0.0.1:9009
IDENA_API_KEY_FILE=/etc/pohw/secrets/idena-api.key

# Experiment 1 uses patched Bitcoin Core directly. The old Experiment 0 custom
# fork-chain RPC must remain unset.
POHW_STRATUM_FORK_CHAIN_RPC_ADDR=
POHW_BITCOIN_RPC_URL=http://127.0.0.1:40414
POHW_BITCOIN_EXPECTED_CHAIN=pohw
POHW_BITCOIN_RPC_COOKIE_FILE=/run/bitcoin-pohw-rpc/.cookie
POHW_BITCOIN_RPC_ALLOW_REMOTE=false

POHW_STRATUM_BUILD_JOB_FROM_RPC=false
POHW_STRATUM_BUILD_POHW_JOB_FROM_RPC=false
POHW_STRATUM_DERIVE_POHW_PAYOUTS_FROM_STATE=true
POHW_STRATUM_AUTO_SUBMIT_BLOCKS=true
POHW_STRATUM_ALLOW_MAINNET_SUBMIT=false
POHW_STRATUM_BIND_ADDR=127.0.0.1:3333
POHW_STRATUM_ALLOW_NON_LOOPBACK=false
POHW_STRATUM_JOB_REFRESH_INTERVAL_SECONDS=5
POHW_STRATUM_DYNAMIC_MIN_SNAPSHOT_VOTERS=1
POHW_STRATUM_BLOCK_CANDIDATE_DIR=/srv/sharechain/pohw-experiment-1-511f8b0b/block-candidates
POHW_PAYOUT_CANDIDATE_DIR=/srv/sharechain/pohw-experiment-1-511f8b0b/payout-candidates
POHW_STRATUM_POHW_COMMITMENT_FILE=/srv/sharechain/pohw-commitment.json
POHW_STRATUM_APPEND=true

# Mainnet handoff is a separate mechanism and is not part of Experiment 1.
POHW_MAINNET_HANDOFF_ACTIVE=false
POHW_MAINNET_HANDOFF_ENABLED=false
