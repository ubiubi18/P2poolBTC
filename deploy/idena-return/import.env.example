# Pi destination node. Its existing nodekey, API key, and IPFS identity are preserved.
IDENA_IMPORT_SERVICE=idena.service
IDENA_IMPORT_DATADIR=/var/lib/idena
IDENA_IMPORT_INBOX_ROOT=/var/lib/idena-return-inbox
IDENA_IMPORT_BACKUP_ROOT=/var/lib/idena-return-backup
IDENA_IMPORT_FAILED_ROOT=/var/lib/idena-return-failed
IDENA_IMPORT_STATE_DIR=/var/lib/idena-return-state
IDENA_IMPORT_RPC_TIMEOUT_SECONDS=900
IDENA_IMPORT_LOCK_TIMEOUT_SECONDS=900
IDENA_IMPORT_MIN_FREE_BYTES=10737418240
IDENA_TRANSFER_LOCK_FILE=/run/lock/idena-return-transfer.lock
IDENA_TRANSFER_GROUP=idena-return
