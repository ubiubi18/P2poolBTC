# Hetzner source node. This identity must be temporary and not online/mining.
IDENA_EXPORT_SERVICE=idena-bootstrap.service
IDENA_EXPORT_DATADIR=/srv/idena
IDENA_EXPORT_DIR=/srv/idena-return-export
IDENA_EXPORT_STATE_DIR=/var/lib/idena-return
IDENA_EXPORT_MIN_HEIGHT=0
IDENA_EXPORT_MIN_PEERS=1
IDENA_EXPORT_STABLE_SECONDS=120
IDENA_EXPORT_MIN_FREE_BYTES=10737418240

# Dedicated write-only rrsync account on the Pi's Tailscale address.
IDENA_RETURN_TARGET=idena-return@100.64.0.10
IDENA_RETURN_DIR=current
IDENA_RETURN_SSH_PORT=2222
IDENA_RETURN_SSH_KEY_FILE=/etc/idena-return/id_ed25519
IDENA_RETURN_KNOWN_HOSTS_FILE=/etc/idena-return/known_hosts
IDENA_RETURN_MIN_FREE_BYTES=10737418240
