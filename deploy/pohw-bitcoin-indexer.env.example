# Host-only inherited Bitcoin history index. Contains paths and loopback binds,
# never RPC credentials or cookie contents.
POHW_ELECTRS_BIN=/usr/local/libexec/pohw/electrs
POHW_BITCOIN_INDEX_DB_DIR=/srv/bitcoin/esplora-index
POHW_BITCOIN_INDEX_DAEMON_DIR=/srv/bitcoin/mainnet
POHW_BITCOIN_INDEX_DAEMON_RPC_ADDR=127.0.0.1:8332
POHW_BITCOIN_INDEX_ELECTRUM_ADDR=127.0.0.1:50001
POHW_BITCOIN_INDEX_HTTP_ADDR=127.0.0.1:3002
POHW_BITCOIN_INDEX_MONITORING_ADDR=127.0.0.1:4225
