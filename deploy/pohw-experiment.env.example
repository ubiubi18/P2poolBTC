# PoHW P2Pool community experiment environment.
# Copy to .pohw-experiment.env for local development or /etc/pohw/p2pool.env on a Pi.
# Do not put raw API keys, passwords, private keys, or dashboard tokens in this file.

# Required safety acknowledgement. This experiment has no coin value and no deposits.
POHW_EXPERIMENT_NO_VALUE_ACK=I_UNDERSTAND_NO_VALUE

# Repository and local replay state.
POHW_WORKDIR=/mnt/ssd/p2pool
POHW_DATADIR=/mnt/ssd/pohw-p2pool
POHW_SNAPSHOT_DIR=/mnt/ssd/pohw-p2pool/snapshots

# Shared fork/testnet activation. Every node should compare the same manifest
# and activation_id before publishing mining work.
POHW_FORK_CHAIN_NAME=pohw-experiment-0
POHW_FORK_LAUNCH_TIMESTAMP_UTC=
POHW_FORK_ACTIVATION_MANIFEST=/mnt/ssd/pohw-p2pool/fork-activation.json
POHW_FORK_POST_FORK_POW_LIMIT_BITS=207fffff
POHW_FORK_TARGET_SPACING_SECONDS=600
POHW_FORK_TIMESTAMP_SEARCH_WINDOW_BLOCKS=4096
POHW_FORK_INHERITED_UTXO_SPENDING_ENABLED=false
POHW_FORK_ALLOW_NON_MAINNET_RPC=false

# Local participant identity. Pick a stable lowercase id such as alice, bob, node-01.
POHW_MINER_ID=
POHW_IDENA_ADDRESS=
POHW_DASHBOARD_IDENA_ADDRESS=

# Gossip mesh. Keep peers as comma-separated host:port values exchanged out of band.
POHW_GOSSIP_BIND_ADDR=127.0.0.1:40406
POHW_ADVERTISE_ADDR=
POHW_PEER_ADDRS=
POHW_ALLOW_PUBLIC_PEERS=false
POHW_EXPERIMENT_REGISTER_PEERS=false
POHW_MAX_PEERS_PER_ROUND=32
POHW_MAX_PARALLEL_PEERS=4

# Local Stratum mining adapter. Keep loopback for a same-host miner.
# For a LAN/rented-hashrate endpoint, bind to the node IP, set
# POHW_STRATUM_ALLOW_NON_LOOPBACK=true, create a chmod 600 password file, and firewall the port.
POHW_STRATUM_BIND_ADDR=127.0.0.1:3333
POHW_STRATUM_ALLOW_NON_LOOPBACK=false
POHW_STRATUM_PASSWORD_FILE=/etc/pohw/stratum.password
# For dry-run sharechain work, build a generic job from local Bitcoin RPC before Stratum starts.
POHW_STRATUM_BUILD_JOB_FROM_RPC=false
# For payout-aware rehearsal, build a job whose coinbase contains the verified payout schedule,
# vault output, and POHW1 commitment. Keep the generic flag above false when this is true.
POHW_STRATUM_BUILD_POHW_JOB_FROM_RPC=false
POHW_STRATUM_PAYOUT_SCHEDULE_FILE=/mnt/ssd/pohw-p2pool/payout-schedule.json
POHW_STRATUM_POHW_COMMITMENT_FILE=/mnt/ssd/pohw-p2pool/pohw-commitment.json
# RPC-built jobs are refreshed in memory and pushed to subscribed miners at this interval.
POHW_STRATUM_JOB_REFRESH_INTERVAL_SECONDS=5
# Explicit opt-in: submit complete target-meeting block candidates to Bitcoin RPC immediately.
POHW_STRATUM_AUTO_SUBMIT_BLOCKS=false
POHW_STRATUM_BLOCK_CANDIDATE_DIR=/mnt/ssd/pohw-p2pool/block-candidates
POHW_BITCOIN_RPC_URL=http://127.0.0.1:8332
# For a dedicated disk, update this and the later Bitcoin datadir/cookie paths together.
POHW_BITCOIN_RPC_COOKIE_FILE=/mnt/ssd/bitcoin/bitcoin-core-mainnet/.cookie
POHW_BITCOIN_RPC_ALLOW_REMOTE=false
# The packaged mining-job.example.json is refused unless POHW_ALLOW_EXAMPLE_MINING_JOB=true is set
# for an explicit local dry-run.
POHW_STRATUM_JOB_FILE=/mnt/ssd/pohw-p2pool/mining-job.json
POHW_ALLOW_EXAMPLE_MINING_JOB=false
# Leave empty for Bitcoin Stratum diff-1. If you change POHW_STRATUM_DIFFICULTY,
# set the matching 32-byte target here so sharechain accounting credits the same work.
POHW_STRATUM_SHARE_TARGET=
POHW_STRATUM_DIFFICULTY=1
POHW_STRATUM_EXTRANONCE2_SIZE=4
POHW_STRATUM_MAX_LINE_BYTES=16384
POHW_STRATUM_IDLE_TIMEOUT_SECONDS=900
POHW_STRATUM_APPEND=true
POHW_IDENA_SNAPSHOT_ID=
POHW_IDENA_SNAPSHOT_PROOF_ROOT=

# Dashboard API. Non-loopback mode needs a strong token file and explicit browser origins.
POHW_DASHBOARD_BIND_ADDR=127.0.0.1:40407
POHW_DASHBOARD_ALLOW_NON_LOOPBACK=false
POHW_DASHBOARD_API_TOKEN_FILE=/etc/pohw/dashboard-api.token
POHW_DASHBOARD_ALLOWED_ORIGINS=http://127.0.0.1:5176,http://localhost:5176
POHW_DASHBOARD_UI_BIND_HOST=127.0.0.1
POHW_DASHBOARD_UI_PORT=5176
POHW_DASHBOARD_UI_API_URL=http://127.0.0.1:40407/dashboard.json
POHW_DASHBOARD_UI_CACHE_DIR=/mnt/ssd/pohw-p2pool/dashboard-ui-cache

# Secret-safe host health. The timer writes sanitized JSON here; bootstrap and
# Stratum RPC-job refresh consult it when it exists.
POHW_HEALTH_STATUS_FILE=/mnt/ssd/pohw-p2pool/health/status.json
POHW_HEALTH_MAX_AGE_SECONDS=180
POHW_BITCOIN_DATADIR=/mnt/ssd/bitcoin/bitcoin-core-mainnet
# Optional auto-bootstrap. The timer runs the real bootstrap once after health
# reports miningReady=true, then writes a marker and stops appending.
POHW_AUTO_BOOTSTRAP_DIR=/mnt/ssd/pohw-p2pool/auto-bootstrap
POHW_AUTO_BOOTSTRAP_OUTPUT_ROOT=/mnt/ssd/pohw-p2pool/output
POHW_AUTO_BOOTSTRAP_APPEND=true
POHW_AUTO_BOOTSTRAP_LOCK_STALE_SECONDS=3600
# Optional network self-recovery. Leave targets empty to use the current default gateway.
POHW_NETWORK_WATCHDOG_STATE_DIR=/var/lib/pohw/network-watchdog
POHW_NETWORK_WATCHDOG_TARGETS=
POHW_NETWORK_WATCHDOG_RESTART_THRESHOLD=3
POHW_NETWORK_WATCHDOG_REBOOT_THRESHOLD=8
POHW_NETWORK_WATCHDOG_LOCK_STALE_SECONDS=300
POHW_NETWORK_WATCHDOG_DRY_RUN=false
# Optional Idena priority guard. The timer stops Bitcoin Core around Idena
# validation/flip sessions and restarts it after the cooldown if the guard
# stopped it itself.
POHW_IDENA_PRIORITY_STATE_DIR=/var/lib/pohw/idena-priority
POHW_IDENA_PRIORITY_LEAD_SECONDS=3600
POHW_IDENA_PRIORITY_COOLDOWN_SECONDS=1800
POHW_IDENA_PRIORITY_RESTORE_BITCOIN=true
POHW_IDENA_PRIORITY_FORCE=false
POHW_IDENA_PRIORITY_DRY_RUN=false
# Optional Bitcoin pressure guard. Its timer is not enabled by the installer
# unless explicitly requested. High utilization alone is normal during IBD and
# does not pause Bitcoin; saturation needs high iowait+util or critical util+latency.
POHW_BITCOIN_PRESSURE_STATE_DIR=/var/lib/pohw/bitcoin-pressure
POHW_BITCOIN_PRESSURE_HIGH_IOWAIT_PERCENT=40
POHW_BITCOIN_PRESSURE_HIGH_UTIL_PERCENT=85
POHW_BITCOIN_PRESSURE_CRITICAL_UTIL_PERCENT=98
POHW_BITCOIN_PRESSURE_CRITICAL_AWAIT_MS=250
POHW_BITCOIN_PRESSURE_LOW_IOWAIT_PERCENT=20
POHW_BITCOIN_PRESSURE_LOW_UTIL_PERCENT=60
POHW_BITCOIN_PRESSURE_LOW_AWAIT_MS=50
POHW_BITCOIN_PRESSURE_HIGH_STREAK=2
POHW_BITCOIN_PRESSURE_LOW_STREAK=3
POHW_BITCOIN_PRESSURE_COOLDOWN_SECONDS=1800
POHW_BITCOIN_PRESSURE_RESTORE_BITCOIN=true
POHW_BITCOIN_PRESSURE_STOP_WHEN_MINING_READY=false
POHW_BITCOIN_PRESSURE_FORCE=false
POHW_BITCOIN_PRESSURE_DRY_RUN=false
# Optional Tailscale remote access. Store auth keys in a chmod 600 file, not here.
POHW_TAILSCALE_HOSTNAME=pibtc
POHW_TAILSCALE_AUTHKEY_FILE=/etc/pohw/tailscale.authkey
POHW_TAILSCALE_ENABLE_SSH=true
# Optional key-only OpenSSH fallback that avoids periodic Tailscale SSH checks.
# It remains tailnet-only and the installer refuses password/root SSH policies.
POHW_TAILSCALE_ENABLE_KEY_SSH_SERVE=false
POHW_TAILSCALE_KEY_SSH_SERVE_PORT=2222
POHW_TAILSCALE_ACCEPT_DNS=false
POHW_TAILSCALE_ACCEPT_ROUTES=false

# Local RPC sources. Keep these loopback unless you understand the trust boundary.
IDENA_RPC_URL=http://127.0.0.1:9009
IDENA_API_KEY_FILE=/mnt/ssd/idena/idena-data/api.key
IDENA_REWARD_LEDGER_DB=/mnt/ssd/pohw-p2pool/rewards/reward_ledger.sqlite3
IDENA_REWARD_INDEXER_SCRIPT=/mnt/ssd/p2pool/pohw_idena_rpc/idena_reward_indexer.py
IDENA_EXACT_REWARD_SQL_FILE=/mnt/ssd/p2pool/scripts/pohw-export-idena-indexer-rewards.sql
# Consensus snapshots score exactly one epoch. Leave blank for the latest canonical completed epoch.
IDENA_REWARD_EPOCH=
# Optional: exact reward sync from official idena-indexer Postgres.
# Store the URL in a chmod 600 file; do not put database passwords in this env file.
IDENA_INDEXER_DATABASE_URL_FILE=
IDENA_INDEXER_PSQL_BIN=psql
IDENA_INDEXER_EXPORT_TIMEOUT_SECONDS=300
# Optional: exact completed-epoch reward sync from the official public Idena API.
# Used only when IDENA_OFFICIAL_API_SYNC=true and no Postgres URL is configured.
IDENA_OFFICIAL_API_SYNC=false
IDENA_OFFICIAL_API_BASE_URL=https://api.idena.io/api
# Leave blank to import the ten completed epochs needed for invitation liabilities,
# or set comma-separated epochs for an explicit backfill.
IDENA_OFFICIAL_API_EPOCHS=
IDENA_OFFICIAL_API_COMPLETED_EPOCHS=10
IDENA_OFFICIAL_API_PAGE_LIMIT=100
IDENA_OFFICIAL_API_MINING_PAGE_LIMIT=20
IDENA_OFFICIAL_API_TIMEOUT_SECONDS=30
IDENA_OFFICIAL_API_RETRIES=4
IDENA_OFFICIAL_API_REQUEST_DELAY_SECONDS=0
IDENA_OFFICIAL_API_SKIP_MINING_SUMMARIES=false
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_COOKIE_FILE=/mnt/ssd/bitcoin/bitcoin-core-mainnet/.cookie

# Optional paths if you do not use the default build output.
POHW_P2POOL_NODE_BIN=
POHW_IDENA_INDEXER_BIN=
POHW_MINING_SECRET_KEY_FILE=
POHW_NODE_SECRET_KEY_FILE=

# Optional report/preflight output directory. Defaults to output/.
POHW_EXPERIMENT_OUTPUT_ROOT=output
