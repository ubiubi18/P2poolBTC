# Hetzner-only bounded Experiment 1 bootstrap miner. Contains no secrets.
POHW_EXPERIMENT_NO_VALUE_ACK=I_UNDERSTAND_NO_VALUE
POHW_BOOTSTRAP_MINER_ALLOW_HOST=I_UNDERSTAND_HETZNER_ONLY
POHW_BOOTSTRAP_MINER_BITCOIN_CLI=/usr/local/libexec/pohw-bitcoin-core-v31.1/bin/bitcoin-cli
POHW_BOOTSTRAP_MINER_BITCOIN_COOKIE_FILE=/run/bitcoin-pohw-rpc/.cookie
POHW_BOOTSTRAP_MINER_BITCOIN_RPC_PORT=40414
POHW_BOOTSTRAP_MINER_SCRIPT=/opt/p2pool/scripts/pohw-stratum-smoke-mine.py
POHW_BOOTSTRAP_MINER_STRATUM_HOST=127.0.0.1
POHW_BOOTSTRAP_MINER_STRATUM_PORT=3333
POHW_BOOTSTRAP_MINER_MAX_HASHES=100000
POHW_BOOTSTRAP_MINER_TIMEOUT_SECONDS=10
