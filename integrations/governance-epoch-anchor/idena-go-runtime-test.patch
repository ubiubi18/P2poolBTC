+func assertGovernanceEpochImportDisabledByDefault(t *testing.T, code []byte) {
+	t.Helper()
+	state, err := appstate.NewAppState(dbm.NewMemDB(), eventbus.New())
+	require.NoError(t, err)
+	state.Initialize(0)
+	state.State.SetGlobalEpoch(7)
+	state.State.SetEpochBlock(42)
+
+	key, err := crypto.GenerateKeyFromSeed(rand.New(rand.NewSource(1)))
+	require.NoError(t, err)
+	metrics := governanceMetricsForAddress(crypto.PubkeyToAddress(key.PublicKey))
+	attachment := attachments.CreateDeployContractAttachment(
+		common.Hash{}, code, nil,
+		[]byte(governanceInitialCID),
+		[]byte(governanceParameterCID),
+		[]byte(metrics.root),
+		[]byte(governanceMetricsEpoch),
+	)
+	payload, err := attachment.ToBytes()
+	require.NoError(t, err)
+	transaction, err := types.SignTx(&types.Transaction{
+		Epoch:        7,
+		AccountNonce: 1,
+		Type:         types.DeployContractTx,
+		Payload:      payload,
+		Amount:       big.NewInt(0),
+	}, key)
+	require.NoError(t, err)
+
+	vm := NewWasmVM(state, nil, createHeader(42, 1234567), governanceRuntimeConfig(), true, nil)
+	require.Zero(t, vm.features, "inactive candidate unexpectedly enabled node features")
+	receipt := vm.Run(transaction, governanceWasmGasLimit)
+	require.False(t, receipt.Success, "disabled resolver accepted env.epoch_block")
+	require.Contains(t, fmt.Sprint(receipt.Error), "epoch_block")
+	require.Empty(t, state.State.GetContractCode(receipt.ContractAddress))
+}
+
