+func TestEpochBlockFeatureIsExplicitAndLegacyEntryPointsStayDisabled(t *testing.T) {
+	callCode := decodeHexContract(t, epochCallContractHex)
+	deployCode := decodeHexContract(t, epochDeployContractHex)
+
+	disabled := NewMockHostEnv()
+	_, _, err := lib.Execute(
+		lib.NewGoAPI(disabled, &lib.GasMeter{}), callCode, "read", nil,
+		lib.Address{}, 1_000_000, false,
+	)
+	require.ErrorContains(t, err, "epoch_block")
+	require.Zero(t, *disabled.epochBlockCalls)
+	_, _, err = lib.Deploy(
+		lib.NewGoAPI(disabled, &lib.GasMeter{}), deployCode, nil,
+		lib.Address{}, 4_000_000, false,
+	)
+	require.ErrorContains(t, err, "epoch_block")
+	require.Zero(t, *disabled.epochBlockCalls)
+
+	enabled := NewMockHostEnv()
+	gas, _, err := lib.ExecuteWithFeatures(
+		lib.NewGoAPI(enabled, &lib.GasMeter{}), callCode, "read", nil,
+		lib.Address{}, 1_000_000, false, lib.FeatureEpochBlock,
+	)
+	require.NoError(t, err)
+	require.GreaterOrEqual(t, gas, uint64(100_000+37))
+	require.Equal(t, 1, *enabled.epochBlockCalls)
+	_, _, err = lib.DeployWithFeatures(
+		lib.NewGoAPI(enabled, &lib.GasMeter{}), deployCode, nil,
+		lib.Address{}, 4_000_000, false, lib.FeatureEpochBlock,
+	)
+	require.NoError(t, err)
+	require.Equal(t, 2, *enabled.epochBlockCalls)
+
+	_, _, err = lib.ExecuteWithFeatures(
