@@ -20,6 +20,35 @@ type WasmVM struct {
 	cfg                 *config.Config
 	commitToState       bool
 	statsCollector      collector.StatsCollector
+	features            lib.FeatureMask
+}
+
+const governanceEpochAnchorNetworkID uint32 = 10002
+
+type governanceEpochAnchorActivation struct {
+	networkID        uint32
+	activationHeight *uint64
+}
+
+func governanceEpochAnchorActivationSource() governanceEpochAnchorActivation {
+	return governanceEpochAnchorActivation{
+		networkID:        governanceEpochAnchorNetworkID,
+		activationHeight: nil,
+	}
+}
+
+func governanceWasmFeatures(cfg *config.Config, head *types.Header) lib.FeatureMask {
+	if cfg == nil || head == nil {
+		return 0
+	}
+	activation := governanceEpochAnchorActivationSource()
+	if cfg.Network != activation.networkID || activation.activationHeight == nil {
+		return 0
+	}
+	if head.Height() < *activation.activationHeight {
+		return 0
+	}
+	return lib.FeatureEpochBlock
 }
 
