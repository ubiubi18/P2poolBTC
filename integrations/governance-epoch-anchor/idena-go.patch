@@ -0,0 +1,44 @@
+package wasm
+
+import (
+	"math"
+	"testing"
+
+	"github.com/idena-network/idena-go/common/eventbus"
+	"github.com/idena-network/idena-go/config"
+	"github.com/idena-network/idena-go/core/appstate"
+	"github.com/idena-network/idena-go/vm/costs"
+	"github.com/idena-network/idena-wasm-binding/lib"
+	"github.com/stretchr/testify/require"
+	dbm "github.com/tendermint/tm-db"
+)
+
+func TestGovernanceEpochAnchorActivationSourceIsFailClosed(t *testing.T) {
+	activation := governanceEpochAnchorActivationSource()
+	require.Equal(t, uint32(10002), activation.networkID)
+	require.Nil(t, activation.activationHeight)
+
+	for _, height := range []uint64{0, 1, math.MaxUint64} {
+		candidate := &config.Config{Network: governanceEpochAnchorNetworkID}
+		require.Zero(t, governanceWasmFeatures(candidate, createHeader(height, 1)))
+
+		mainnet := &config.Config{Network: 1}
+		require.Zero(t, governanceWasmFeatures(mainnet, createHeader(height, 1)))
+	}
+	require.Zero(t, governanceWasmFeatures(nil, createHeader(1, 1)))
+	require.Zero(t, governanceWasmFeatures(&config.Config{Network: governanceEpochAnchorNetworkID}, nil))
+}
+
+func TestEpochBlockUsesReadGlobalStateGas(t *testing.T) {
+	state, err := appstate.NewAppState(dbm.NewMemDB(), eventbus.New())
+	require.NoError(t, err)
+	state.Initialize(0)
+	state.State.SetEpochBlock(43)
+
+	env := NewWasmEnv(state, nil, nil, createHeader(43, 1), "test", false, false, false, nil)
+	meter := &lib.GasMeter{}
+	meter.SetRemainingGas(math.MaxUint64)
+
+	require.Equal(t, uint64(43), env.EpochBlock(meter))
+	require.Equal(t, costs.GasToWasmGas(costs.ReadGlobalStateGas), meter.GasConsumed())
+}
