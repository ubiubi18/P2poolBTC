+#[test]
+fn test_feature_abi_is_append_only_and_fails_closed() {
+    use std::mem::{offset_of, size_of};
+
+    use crate::exports::{GoApi, GoApi_v2, GoApi_vtable, GO_API_V2_ABI_VERSION};
+
+    assert_eq!(size_of::<GoApi_vtable>(), 31 * size_of::<usize>());
+    assert_eq!(
+        size_of::<GoApi>(),
+        2 * size_of::<usize>() + size_of::<GoApi_vtable>()
+    );
+    assert_eq!(
+        size_of::<GoApi_v2>(),
+        size_of::<GoApi>() + 2 * size_of::<u32>() + size_of::<usize>()
+    );
+    assert_eq!(offset_of!(GoApi_v2, state), offset_of!(GoApi, state));
+    assert_eq!(
+        offset_of!(GoApi_v2, gas_meter),
+        offset_of!(GoApi, gas_meter)
+    );
+    assert_eq!(offset_of!(GoApi_v2, vtable), offset_of!(GoApi, vtable));
+    assert_eq!(offset_of!(GoApi_v2, abi_version), size_of::<GoApi>());
+    assert!(offset_of!(GoApi_v2, abi_size) > offset_of!(GoApi_v2, abi_version));
+    assert!(offset_of!(GoApi_v2, epoch_block) > offset_of!(GoApi_v2, abi_size));
+
+    let size = u32::try_from(size_of::<GoApi_v2>()).unwrap();
+    assert!(crate::exports::validate_feature_abi(
+        GO_API_V2_ABI_VERSION,
+        size,
+        Some(epoch_block_callback),
+        crate::FEATURE_EPOCH_BLOCK,
+    )
+    .is_ok());
+    assert!(crate::exports::validate_feature_abi(
+        GO_API_V2_ABI_VERSION + 1,
+        size,
+        Some(epoch_block_callback),
+        crate::FEATURE_EPOCH_BLOCK,
+    )
+    .is_err());
+    assert!(crate::exports::validate_feature_abi(
+        GO_API_V2_ABI_VERSION,
+        size - 1,
+        Some(epoch_block_callback),
+        crate::FEATURE_EPOCH_BLOCK,
+    )
+    .is_err());
+    assert!(crate::exports::validate_feature_abi(
+        GO_API_V2_ABI_VERSION,
+        size,
+        None,
+        crate::FEATURE_EPOCH_BLOCK,
+    )
+    .is_err());
+    assert!(crate::exports::validate_feature_abi(
+        GO_API_V2_ABI_VERSION,
+        size,
+        Some(epoch_block_callback),
+        1 << 63,
+    )
+    .is_err());
+}
