+pub(crate) fn validate_feature_abi(
+    abi_version: u32,
+    abi_size: u32,
+    epoch_block: Option<extern "C" fn(*const api_t, *mut u64, *mut u64) -> i32>,
+    features: u64,
+) -> VmResult<()> {
+    if abi_version != GO_API_V2_ABI_VERSION {
+        return Err(VmError::custom(format!(
+            "unsupported GoApi_v2 ABI version: expected {}, found {}",
+            GO_API_V2_ABI_VERSION, abi_version
+        )));
+    }
+    if abi_size as usize != mem::size_of::<GoApi_v2>() {
+        return Err(VmError::custom(format!(
+            "unsupported GoApi_v2 ABI size: expected {}, found {}",
+            mem::size_of::<GoApi_v2>(),
+            abi_size
+        )));
+    }
+    if features & !KNOWN_FEATURES != 0 {
+        return Err(VmError::custom(format!(
+            "unsupported runtime feature mask: {:#x}",
+            features
+        )));
+    }
+    if features & FEATURE_EPOCH_BLOCK != 0 && epoch_block.is_none() {
+        return Err(VmError::custom(
+            "epoch_block feature requires the GoApi_v2 callback",
+        ));
+    }
+    Ok(())
+}
