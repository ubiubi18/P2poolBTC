+const fs = require('fs')
+const path = require('path')
+
+describe('AI-first desktop navigation', () => {
+  it('uses idena.AI as the default page and keeps the required product order', () => {
+    const root = path.resolve(__dirname, '..', '..', '..')
+    const indexSource = fs.readFileSync(
+      path.join(root, 'renderer/pages/index.js'),
+      'utf8'
+    )
+    const sidebarSource = fs.readFileSync(
+      path.join(root, 'renderer/shared/components/sidebar.js'),
+      'utf8'
+    )
+
+    expect(indexSource).toMatch(/import AiChatPage from '\.\/ai-chat'/)
+    expect(indexSource).toMatch(/export default AiChatPage/)
+
+    const labels = [
+      "t('idena.AI')",
+      "t('idena.BUILDER')",
+      "t('idena.DAO')",
+      "t('idena.SOCIAL')",
+    ]
+    const positions = labels.map((label) => sidebarSource.indexOf(label))
+    expect(positions.every((position) => position >= 0)).toBe(true)
+    expect(positions).toEqual(
+      positions.slice().sort((left, right) => left - right)
+    )
+    expect(sidebarSource).toContain("t('My Idena')")
+  })
+})
