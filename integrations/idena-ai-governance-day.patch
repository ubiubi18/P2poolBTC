+import React, {act} from 'react'
+import {createRoot} from 'react-dom/client'
+import {ChakraProvider} from '@chakra-ui/react'
+import GovernanceDayCard from './governance-day-card'
+import {createExperimentalGovernanceState} from '../utils/epoch-governance'
+
+const mockPush = jest.fn()
+
+global.IS_REACT_ACT_ENVIRONMENT = true
+
+jest.mock('next/router', () => ({
+  useRouter: () => ({push: mockPush, pathname: '/ai-chat'}),
+}))
+
+jest.mock('react-i18next', () => ({
+  useTranslation: () => ({
+    t: (value, params = {}) =>
+      Object.entries(params).reduce(
+        (text, [key, replacement]) =>
+          text.replace(`{{${key}}}`, String(replacement)),
+        value
+      ),
+  }),
+}))
+
+describe('GovernanceDayCard', () => {
+  let container
+  let root
+
+  beforeEach(() => {
+    container = document.createElement('div')
+    document.body.appendChild(container)
+    root = createRoot(container)
+    mockPush.mockClear()
+  })
+
+  afterEach(() => {
+    act(() => root.unmount())
+    container.remove()
+  })
+
+  it('renders the shared Governance Day state and AI-first review action', () => {
+    act(() => {
+      root.render(
+        <ChakraProvider>
+          <GovernanceDayCard state={createExperimentalGovernanceState(421)} />
+        </ChakraProvider>
+      )
+    })
+
+    expect(container.textContent).toContain('Governance Day - Epoch 421')
+    expect(container.textContent).toContain('2 proposals in the frozen ballot')
+    expect(container.textContent).toContain('Review with idena.AI')
+    expect(container.textContent).toContain('Inspect manually')
+  })
+})
