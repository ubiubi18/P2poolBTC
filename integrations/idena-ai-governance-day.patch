+          </Text>
+          <Text>{state?.reviewSummary?.commitState || t('Not committed')}</Text>
+          <Text>{state?.reviewSummary?.revealState || t('Not revealed')}</Text>
+        </Flex>
+
+        <HStack spacing={2} flexWrap="wrap">
+          <Button
+            variant="primary"
