index 0000000000000000000000000000000000000000..1e27fa07a8717f499d158d2b3453869ddbe81649
--- /dev/null
+++ b/renderer/pages/builder.js
@@ -0,0 +1,375 @@
+/* eslint-disable react/prop-types */
+import React from 'react'
+import {
+  Badge,
+  Box,
+  Code,
+  Flex,
+  FormControl,
+  FormLabel,
+  HStack,
+  Stack,
+  Text,
+} from '@chakra-ui/react'
+import {useRouter} from 'next/router'
+import {useTranslation} from 'react-i18next'
+import Layout from '../shared/components/layout'
+import {
+  Checkbox,
+  Input,
+  Page,
+  PageTitle,
+  Select,
+  Textarea,
+} from '../shared/components/components'
+import {PrimaryButton, SecondaryButton} from '../shared/components/button'
+import {FolderIcon, LockIcon} from '../shared/components/icons'
+import {useChainState} from '../shared/providers/chain-context'
+
+const BUILDER_OPERATIONS = Object.freeze([
+  'inspectRepository',
+  'inspectSelectedFiles',
+  'reviewCodeProposal',
+  'findSecurityIssues',
+  'suggestTests',
+  'proposePatch',
+  'comparePatches',
+  'prepareRevertProposal',
+])
+
+const PROVIDER_MODELS = Object.freeze({
+  'local-ai': 'local-configured-model',
+  openai: 'gpt-5.5',
+  anthropic: 'claude-3-7-sonnet-latest',
+  deepinfra: 'Qwen/Qwen3.6-35B-A3B',
+  openrouter: 'openai/gpt-4o-mini',
+  'openai-compatible': 'gpt-4o-mini',
+})
+
+function getAiBridge() {
+  if (
+    global.aiSolver &&
+    typeof global.aiSolver.runGovernanceOperation === 'function'
+  ) {
+    return global.aiSolver
+  }
+
+  throw new Error('Governance AI bridge is unavailable in this build')
+}
+
+function formatRunError(error) {
+  return String((error && error.message) || error || 'Unknown Builder error')
+}
+
+export default function BuilderPage() {
+  const {t} = useTranslation()
+  const router = useRouter()
+  const {loading, syncing, offline} = useChainState()
+  const requestedOperation = String(router.query?.action || '').trim()
+  const [operation, setOperation] = React.useState(
+    BUILDER_OPERATIONS.includes(requestedOperation)
+      ? requestedOperation
+      : 'reviewCodeProposal'
+  )
+  const [provider, setProvider] = React.useState('local-ai')
+  const [model, setModel] = React.useState(PROVIDER_MODELS['local-ai'])
+  const [baseUrl, setBaseUrl] = React.useState('http://127.0.0.1:11434/v1')
+  const [repository, setRepository] = React.useState('local/fixture-repository')
+  const [sourcePath, setSourcePath] = React.useState('src/example.js')
+  const [sourceText, setSourceText] = React.useState(
+    'export function add(left, right) {\n  return left + right\n}\n'
+  )
+  const [userInstruction, setUserInstruction] = React.useState(
+    'Review this selected fixture and identify focused tests.'
+  )
+  const [workspaceApproved, setWorkspaceApproved] = React.useState(false)
+  const [runResult, setRunResult] = React.useState(null)
+  const [runError, setRunError] = React.useState('')
+  const [isRunning, setIsRunning] = React.useState(false)
+
+  React.useEffect(() => {
+    if (BUILDER_OPERATIONS.includes(requestedOperation)) {
+      setOperation(requestedOperation)
+    }
+  }, [requestedOperation])
+
+  const buildPayload = React.useCallback(
+    (approval = {}) => ({
+      operation,
+      provider,
+      model,
+      providerConfig: provider === 'openai-compatible' ? {baseUrl} : undefined,
+      repository,
+      userInstruction,
+      selectedFiles: [{path: sourcePath, content: sourceText}],
+      timeoutMs: 120000,
+      maxOutputTokens: 1200,
+      providerDailyBudgetRemainingUsd: 0.25,
+      ...approval,
+    }),
+    [
+      baseUrl,
+      model,
+      operation,
+      provider,
+      repository,
+      sourcePath,
+      sourceText,
+      userInstruction,
+    ]
+  )
+
+  const run = React.useCallback(
+    async (approval = {}) => {
+      if (!workspaceApproved) {
+        setRunError(t('Approve the listed workspace context first.'))
+        return
+      }
+
+      setIsRunning(true)
+      setRunError('')
+      try {
+        const result = await getAiBridge().runGovernanceOperation(
+          buildPayload(approval)
+        )
+        setRunResult(result)
+      } catch (error) {
+        setRunError(formatRunError(error))
+      } finally {
+        setIsRunning(false)
+      }
+    },
+    [buildPayload, t, workspaceApproved]
+  )
+
+  const handleProviderChange = (event) => {
+    const nextProvider = event.target.value
+    setProvider(nextProvider)
+    setModel(PROVIDER_MODELS[nextProvider] || '')
+    setRunResult(null)
+  }
+
+  return (
+    <Layout
+      loading={loading}
+      syncing={syncing}
+      offline={offline}
+      allowWhenNodeUnavailable
+    >
+      <Page minW={0}>
+        <Stack spacing={5} w="full" maxW="5xl">
+          <Flex align="center" justify="space-between" gap={3}>
+            <HStack spacing={3}>
+              <FolderIcon boxSize="6" color="brandBlue.500" />
+              <PageTitle mb={0}>{t('idena.BUILDER')}</PageTitle>
+            </HStack>
+            <HStack spacing={2}>
+              <Badge colorScheme="purple">{t('Experimental')}</Badge>
+              <Badge colorScheme="orange">{t('No automatic changes')}</Badge>
+            </HStack>
+          </Flex>
+
+          <Box
+            borderWidth="1px"
+            borderColor="gray.100"
+            borderRadius="md"
+            bg="white"
+            p={4}
+          >
+            <Stack spacing={4}>
+              <Flex gap={4} direction={['column', 'row']}>
+                <FormControl>
+                  <FormLabel>{t('Operation')}</FormLabel>
+                  <Select
+                    value={operation}
+                    onChange={(event) => {
+                      setOperation(event.target.value)
+                      setRunResult(null)
+                    }}
+                  >
+                    {BUILDER_OPERATIONS.map((value) => (
+                      <option key={value} value={value}>
+                        {value}
+                      </option>
+                    ))}
+                  </Select>
+                </FormControl>
+                <FormControl>
+                  <FormLabel>{t('Provider')}</FormLabel>
+                  <Select value={provider} onChange={handleProviderChange}>
+                    {Object.keys(PROVIDER_MODELS).map((value) => (
+                      <option key={value} value={value}>
+                        {value}
+                      </option>
+                    ))}
+                  </Select>
+                </FormControl>
+                <FormControl>
+                  <FormLabel>{t('Model')}</FormLabel>
+                  <Input
+                    value={model}
+                    onChange={(event) => setModel(event.target.value)}
+                  />
+                </FormControl>
+              </Flex>
+
+              {provider === 'openai-compatible' ? (
+                <FormControl>
+                  <FormLabel>{t('OpenAI-compatible endpoint')}</FormLabel>
+                  <Input
+                    value={baseUrl}
+                    onChange={(event) => setBaseUrl(event.target.value)}
+                  />
+                </FormControl>
+              ) : null}
+
+              <Flex gap={4} direction={['column', 'row']}>
+                <FormControl flex={2}>
+                  <FormLabel>{t('Approved repository')}</FormLabel>
+                  <Input
+                    value={repository}
+                    onChange={(event) => setRepository(event.target.value)}
+                  />
+                </FormControl>
+                <FormControl flex={1}>
+                  <FormLabel>{t('Selected relative path')}</FormLabel>
+                  <Input
+                    value={sourcePath}
+                    onChange={(event) => setSourcePath(event.target.value)}
+                  />
+                </FormControl>
+              </Flex>
+
+              <FormControl>
+                <FormLabel>{t('Selected source context')}</FormLabel>
+                <Textarea
+                  value={sourceText}
+                  minH="180px"
+                  fontFamily="mono"
+                  onChange={(event) => setSourceText(event.target.value)}
+                />
+              </FormControl>
+
+              <FormControl>
+                <FormLabel>{t('Review objective')}</FormLabel>
+                <Textarea
+                  value={userInstruction}
+                  minH="80px"
+                  onChange={(event) => setUserInstruction(event.target.value)}
+                />
+              </FormControl>
+
+              <Checkbox
+                isChecked={workspaceApproved}
+                onChange={(event) => {
+                  setWorkspaceApproved(event.target.checked)
+                  setRunResult(null)
+                }}
+              >
+                {t('Approve only the repository and source bytes listed above')}
+              </Checkbox>
+
+              <HStack spacing={2} flexWrap="wrap">
+                <PrimaryButton
+                  leftIcon={<LockIcon boxSize="4" />}
+                  isDisabled={!workspaceApproved}
+                  isLoading={isRunning}
+                  onClick={() => run()}
+                >
+                  {t('Preview agent run')}
+                </PrimaryButton>
+                {runResult?.state === 'awaiting_execution_confirmation' ? (
+                  <SecondaryButton
+                    isLoading={isRunning}
+                    onClick={() => run({executionConfirmed: true})}
+                  >
+                    {t('Confirm and run agent')}
+                  </SecondaryButton>
+                ) : null}
+                {runResult?.state === 'awaiting_context_confirmation' ? (
+                  <SecondaryButton
+                    isLoading={isRunning}
+                    onClick={() =>
+                      run({
+                        executionConfirmed: true,
+                        contextDisclosureConfirmed: true,
+                        approvedContextFingerprint:
+                          runResult.contextFingerprint,
+                      })
+                    }
+                  >
+                    {t('Approve listed hosted context and run')}
+                  </SecondaryButton>
+                ) : null}
+              </HStack>
+            </Stack>
+          </Box>
+
+          {runError ? (
+            <Box borderWidth="1px" borderColor="red.200" bg="red.010" p={3}>
+              <Text color="red.600" fontSize="sm">
+                {runError}
+              </Text>
+            </Box>
+          ) : null}
+
+          {runResult ? (
+            <Box
+              borderWidth="1px"
+              borderColor="gray.100"
+              borderRadius="md"
+              bg="white"
+              p={4}
+            >
+              <Stack spacing={3}>
+                <Flex align="center" justify="space-between" gap={3}>
+                  <HStack spacing={2} flexWrap="wrap">
+                    <Badge colorScheme="blue">{runResult.state}</Badge>
+                    <Badge>{runResult.executionKind}</Badge>
+                    <Badge>{runResult.provider}</Badge>
+                    <Badge>{runResult.model}</Badge>
+                  </HStack>
+                  <Text color="muted" fontSize="xs">
+                    {runResult.selectedContext?.totalBytes || 0} {t('bytes')}
+                  </Text>
+                </Flex>
+                <Text color="muted" fontSize="sm">
+                  {runResult.privacy}
+                </Text>
+                <Text fontFamily="mono" fontSize="xs" wordBreak="break-all">
+                  {t('Context fingerprint')}: {runResult.contextFingerprint}
+                </Text>
+                {runResult.estimatedCostUsd !== null ? (
+                  <Text fontSize="sm">
+                    {t('Estimated maximum')}: $
+                    {Number(runResult.estimatedCostUsd).toFixed(6)}
+                  </Text>
+                ) : (
+                  <Text color="muted" fontSize="sm">
+                    {t('Cost estimate unavailable for this model')}
+                  </Text>
+                )}
+                {runResult.output?.text ? (
+                  <Code
+                    display="block"
+                    whiteSpace="pre-wrap"
+                    p={3}
+                    maxH="360px"
+                    overflowY="auto"
+                  >
+                    {runResult.output.text}
+                  </Code>
+                ) : null}
+                {(runResult.limitations || []).map((limitation) => (
+                  <Text key={limitation} color="muted" fontSize="xs">
+                    {limitation}
+                  </Text>
+                ))}
+              </Stack>
+            </Box>
+          ) : null}
+        </Stack>
+      </Page>
+    </Layout>
+  )
+}
