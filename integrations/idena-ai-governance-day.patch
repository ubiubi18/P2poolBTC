+++ b/renderer/shared/utils/epoch-governance.test.js
@@ -0,0 +1,168 @@
+import {
+  buildEpochGovernanceBrief,
+  createBallotCommitPayload,
+  createExperimentalGovernanceState,
+  createLocalEpochBallot,
+  createProposalDiscussionHref,
+  isLocalBallotComplete,
+  prepareBallotCommitIntent,
+  simulateConfirmedLocalRollback,
+  stageLastKnownGoodRollback,
+  updateLocalBallotDecision,
+} from './epoch-governance'
+
+function ballot() {
+  return createLocalEpochBallot({
+    governanceEpoch: 42,
+    voter: '0x0000000000000000000000000000000000000001',
+    frozenProposalSetRoot: 'root-42',
+    proposalIds: ['proposal-a', 'proposal-b'],
+  })
+}
+
+describe('epoch governance renderer state', () => {
+  it('keeps ballot edits local and never marks them signed or submitted', () => {
+    const changed = updateLocalBallotDecision(ballot(), 'proposal-a', {
+      choice: 'NO',
+      localNote: 'Needs another test.',
+    })
+
+    expect(changed.decisions[0]).toEqual({
+      proposalId: 'proposal-a',
+      choice: 'NO',
+      localNote: 'Needs another test.',
+    })
+    expect(changed.signed).toBe(false)
+    expect(changed.submitted).toBe(false)
+  })
+
+  it('requires a complete ballot and explicit confirmation before signing', () => {
+    let draft = updateLocalBallotDecision(ballot(), 'proposal-a', {
+      choice: 'YES',
+    })
+    expect(prepareBallotCommitIntent(draft).canRequestSignature).toBe(false)
+
+    draft = updateLocalBallotDecision(draft, 'proposal-b', {choice: 'ABSTAIN'})
+    expect(isLocalBallotComplete(draft)).toBe(true)
+    expect(prepareBallotCommitIntent(draft).canRequestSignature).toBe(false)
+    expect(
+      prepareBallotCommitIntent(draft, {confirmed: true}).canRequestSignature
+    ).toBe(true)
+    expect(
+      prepareBallotCommitIntent(draft, {confirmed: true}).submitsAutomatically
+    ).toBe(false)
+  })
+
+  it('preserves frozen order and excludes local notes from commit payload', () => {
+    let draft = updateLocalBallotDecision(ballot(), 'proposal-a', {
+      choice: 'YES',
+      localNote: 'private note',
+    })
+    draft = updateLocalBallotDecision(draft, 'proposal-b', {choice: 'NO'})
+
+    expect(createBallotCommitPayload(draft)).toEqual({
+      schemaVersion: 'EpochBallotCommitPreparationV1',
+      governanceEpoch: 42,
+      voterAddress: '0x0000000000000000000000000000000000000001',
+      votingPowerSnapshotReference: '',
+      frozenProposalSetRoot: 'root-42',
+      orderedProposalIds: ['proposal-a', 'proposal-b'],
+      choices: ['YES', 'NO'],
+    })
+  })
+
+  it('rejects duplicate frozen IDs and unknown local choices', () => {
+    expect(() =>
+      createLocalEpochBallot({
+        governanceEpoch: 1,
+        proposalIds: ['same', 'same'],
+      })
+    ).toThrow(/duplicate/i)
+    expect(() =>
+      updateLocalBallotDecision(ballot(), 'not-frozen', {choice: 'YES'})
+    ).toThrow(/not in the frozen ballot/i)
+  })
+
+  it('keeps source facts, AI findings, discussion claims, and notes separate', () => {
+    const fixture = createExperimentalGovernanceState(42)
+    const draft = createLocalEpochBallot({
+      governanceEpoch: 42,
+      frozenProposalSetRoot: fixture.frozenProposalSetRoot,
+      proposalIds: fixture.proposals.map(({proposalId}) => proposalId),
+    })
+    const brief = buildEpochGovernanceBrief({
+      epoch: 42,
+      frozenProposalSetRoot: fixture.frozenProposalSetRoot,
+      proposals: fixture.proposals,
+      ballot: draft,
+    })
+
+    expect(brief.schemaVersion).toBe(1)
+    expect(brief.generatedBy).toMatch(/local experimental/i)
+    expect(brief.proposals[0].title).toBeTruthy()
+    expect(brief.proposals[0].sourceFacts).toBeInstanceOf(Array)
+    expect(brief.proposals[0].aiFindings[0]).toMatch(/AI-generated/i)
+    expect(brief.proposals[0].discussionClaims).toBeInstanceOf(Array)
+    expect(brief.proposals[0].currentLocalBallotChoice).toBe('postponed')
+  })
+
+  it('creates an explicit social discussion route without changing votes', () => {
+    const before = ballot()
+    expect(createProposalDiscussionHref('proposal-a')).toBe(
+      '/social?governanceProposal=proposal-a'
+    )
+    expect(before).toEqual(ballot())
+  })
+
+  it('stages and simulates last-known-good rollback only after verification and confirmation', () => {
+    const recoveryManifest = {
+      schemaVersion: 1,
+      recoveryManifestCid: 'local-test-recovery-cid',
+      lastKnownGoodEcosystemCid: 'local-test-ecosystem-cid',
+      releaseManifestCid: 'local-test-release-cid',
+      previousSourceCid: 'local-test-source-cid',
+      artifactSha256: 'a'.repeat(64),
+      compatibilityMetadataCid: 'local-test-compatibility-cid',
+      rollbackInstructionsCid: 'local-test-instructions-cid',
+      chainRpcRequiredForOnChainRevert: true,
+    }
+    const plan = stageLastKnownGoodRollback({
+      recoveryManifest,
+      verifiedArtifactSha256: 'a'.repeat(64),
+      stagedArtifactPath: 'local-test/staging/idena-node',
+      chainRpcAvailable: false,
+    })
+
+    expect(plan.onChainRevertAvailable).toBe(false)
+    expect(plan.unattendedInstallEnabled).toBe(false)
+    expect(plan.unattendedRollbackEnabled).toBe(false)
+    expect(() => simulateConfirmedLocalRollback(plan)).toThrow(/confirmation/i)
+
+    const result = simulateConfirmedLocalRollback(plan, {confirmed: true})
+    expect(result.simulationOnly).toBe(true)
+    expect(result.filesChanged).toBe(false)
+    expect(result.processesRestarted).toBe(false)
+    expect(result.onChainRevertExecuted).toBe(false)
+  })
+
+  it('fails closed when the staged rollback artifact digest differs', () => {
+    expect(() =>
+      stageLastKnownGoodRollback({
+        recoveryManifest: {
+          schemaVersion: 1,
+          recoveryManifestCid: 'local-test-recovery-cid',
+          lastKnownGoodEcosystemCid: 'local-test-ecosystem-cid',
+          releaseManifestCid: 'local-test-release-cid',
+          previousSourceCid: 'local-test-source-cid',
+          artifactSha256: 'a'.repeat(64),
+          compatibilityMetadataCid: 'local-test-compatibility-cid',
+          rollbackInstructionsCid: 'local-test-instructions-cid',
+          chainRpcRequiredForOnChainRevert: true,
+        },
+        verifiedArtifactSha256: 'b'.repeat(64),
+        stagedArtifactPath: 'local-test/staging/idena-node',
+        chainRpcAvailable: false,
+      })
+    ).toThrow(/digest/i)
+  })
+})
