diff --git a/renderer/shared/utils/epoch-governance.js b/renderer/shared/utils/epoch-governance.js
new file mode 100644
index 0000000000000000000000000000000000000000..b6543897be810b21b220e310bd5164a1a9651cc7
--- /dev/null
+++ b/renderer/shared/utils/epoch-governance.js
@@ -0,0 +1,390 @@
+export const EPOCH_BALLOT_CHOICES = Object.freeze(['YES', 'NO', 'ABSTAIN'])
+
+const EPOCH_BALLOT_CHOICE_SET = new Set(EPOCH_BALLOT_CHOICES)
+
+function normalizeProposalIds(proposalIds) {
+  if (!Array.isArray(proposalIds) || proposalIds.length > 64) {
+    throw new Error('Frozen proposal IDs must be a bounded array')
+  }
+
+  const seen = new Set()
+  return proposalIds.map((value) => {
+    const proposalId = String(value || '').trim()
+    if (!proposalId || proposalId.length > 128) {
+      throw new Error('Frozen proposal ID is invalid')
+    }
+    if (seen.has(proposalId)) {
+      throw new Error(`Duplicate frozen proposal ID: ${proposalId}`)
+    }
+    seen.add(proposalId)
+    return proposalId
+  })
+}
+
+export function createLocalEpochBallot({
+  governanceEpoch,
+  voter,
+  votingPowerSnapshotReference = '',
+  frozenProposalSetRoot,
+  proposalIds,
+}) {
+  const epoch = Number.parseInt(governanceEpoch, 10)
+  if (!Number.isSafeInteger(epoch) || epoch < 0) {
+    throw new Error('Governance epoch is invalid')
+  }
+
+  const normalizedIds = normalizeProposalIds(proposalIds)
+
+  return {
+    schemaVersion: 'LocalEpochBallotDraftV1',
+    governanceEpoch: epoch,
+    voterAddress: String(voter || '').trim(),
+    votingPowerSnapshotReference: String(
+      votingPowerSnapshotReference || ''
+    ).trim(),
+    frozenProposalSetRoot: String(frozenProposalSetRoot || '').trim(),
+    decisions: normalizedIds.map((proposalId) => ({
+      proposalId,
+      choice: null,
+      localNote: '',
+    })),
+    submitted: false,
+    signed: false,
+  }
+}
+
+export function updateLocalBallotDecision(
+  ballot,
+  proposalId,
+  {choice, localNote}
+) {
+  if (ballot && (ballot.submitted || ballot.signed)) {
+    throw new Error('Submitted or signed ballots are immutable')
+  }
+
+  const normalizedId = String(proposalId || '').trim()
+  const normalizedChoice = String(choice || '')
+    .trim()
+    .toUpperCase()
+  if (!EPOCH_BALLOT_CHOICE_SET.has(normalizedChoice)) {
+    throw new Error(`Invalid epoch ballot choice: ${normalizedChoice}`)
+  }
+
+  let found = false
+  const decisions = ballot.decisions.map((decision) => {
+    if (decision.proposalId !== normalizedId) {
+      return decision
+    }
+
+    found = true
+    return {
+      ...decision,
+      choice: normalizedChoice,
+      localNote:
+        typeof localNote === 'undefined'
+          ? decision.localNote
+          : String(localNote || '').slice(0, 4000),
+    }
+  })
+
+  if (!found) {
+    throw new Error(`Proposal is not in the frozen ballot: ${normalizedId}`)
+  }
+
+  return {
+    ...ballot,
+    decisions,
+    submitted: false,
+    signed: false,
+  }
+}
+
+export function isLocalBallotComplete(ballot) {
+  return Boolean(
+    ballot &&
+      Array.isArray(ballot.decisions) &&
+      ballot.decisions.length > 0 &&
+      ballot.decisions.every((decision) =>
+        EPOCH_BALLOT_CHOICE_SET.has(decision.choice)
+      )
+  )
+}
+
+export function prepareBallotCommitIntent(ballot, {confirmed = false} = {}) {
+  const complete = isLocalBallotComplete(ballot)
+
+  return {
+    schemaVersion: 'EpochBallotCommitIntentV1',
+    canRequestSignature: complete && confirmed === true,
+    requiresExplicitConfirmation: confirmed !== true,
+    requiresWalletSignature: true,
+    submitsAutomatically: false,
+    orderedProposalIds: ballot.decisions.map(({proposalId}) => proposalId),
+    encodedChoices: ballot.decisions.map(({choice}) => choice),
+  }
+}
+
+export function createBallotCommitPayload(ballot) {
+  if (!isLocalBallotComplete(ballot)) {
+    throw new Error('Every frozen proposal needs a ballot choice')
+  }
+
+  return {
+    schemaVersion: 'EpochBallotCommitPreparationV1',
+    governanceEpoch: ballot.governanceEpoch,
+    voterAddress: ballot.voterAddress,
+    votingPowerSnapshotReference: ballot.votingPowerSnapshotReference,
+    frozenProposalSetRoot: ballot.frozenProposalSetRoot,
+    orderedProposalIds: ballot.decisions.map(({proposalId}) => proposalId),
+    choices: ballot.decisions.map(({choice}) => choice),
+  }
+}
+
+export function createProposalDiscussionHref(proposalId) {
+  const normalizedId = String(proposalId || '').trim()
+  if (!normalizedId || normalizedId.length > 128) {
+    throw new Error('Proposal ID is invalid')
+  }
+
+  return `/social?governanceProposal=${encodeURIComponent(normalizedId)}`
+}
+
+export function buildEpochGovernanceBrief({
+  epoch,
+  frozenProposalSetRoot,
+  proposals,
+  ballot,
+}) {
+  const localChoiceById = new Map(
+    (ballot?.decisions || []).map(({proposalId, choice, localNote}) => [
+      proposalId,
+      {choice, localNote},
+    ])
+  )
+
+  return {
+    schemaVersion: 1,
+    governanceEpoch: Number(epoch),
+    frozenProposalSetRoot: String(frozenProposalSetRoot || ''),
+    generatedBy: 'idena.AI local experimental brief generator',
+    proposals: (proposals || []).map((proposal) => ({
+      proposalId: proposal.proposalId,
+      title: proposal.title,
+      proposer: proposal.proposer,
+      affectedRepositories: proposal.repositories || [],
+      riskClass: proposal.riskClass,
+      baseCid: proposal.baseCid,
+      candidateCid: proposal.candidateCid,
+      sourceFacts: [
+        `Proposer: ${proposal.proposer}`,
+        `Affected repositories: ${(proposal.repositories || []).join(', ')}`,
+        `Base CID: ${proposal.baseCid}`,
+        `Candidate CID: ${proposal.candidateCid}`,
+      ],
+      testEvidence: proposal.testEvidence || [],
+      aiFindings: proposal.aiFindings || [],
+      discussionClaims: proposal.discussionClaims || [],
+      userNotes: localChoiceById.get(proposal.proposalId)?.localNote
+        ? [localChoiceById.get(proposal.proposalId).localNote]
+        : [],
+      importantChangedFiles: proposal.importantChangedFiles || [],
+      unresolvedCriticalFindings: Number(
+        proposal.unresolvedCriticalFindings || 0
+      ),
+      proposalBondAtoms: String(proposal.proposalBondAtoms || '0'),
+      currentLocalBallotChoice: String(
+        localChoiceById.get(proposal.proposalId)?.choice || 'POSTPONED'
+      ).toLowerCase(),
+    })),
+  }
+}
+
+function requiredText(value, label) {
+  const text = String(value || '').trim()
+  if (!text) throw new Error(`${label} is required`)
+  return text
+}
+
+export function stageLastKnownGoodRollback({
+  recoveryManifest,
+  verifiedArtifactSha256,
+  stagedArtifactPath,
+  chainRpcAvailable,
+}) {
+  if (!recoveryManifest || recoveryManifest.schemaVersion !== 1) {
+    throw new Error('RecoveryManifestV1 is required')
+  }
+
+  const expectedDigest = requiredText(
+    recoveryManifest.artifactSha256,
+    'Recovery artifact SHA-256'
+  ).toLowerCase()
+  const actualDigest = requiredText(
+    verifiedArtifactSha256,
+    'Verified artifact SHA-256'
+  ).toLowerCase()
+  if (
+    !/^[0-9a-f]{64}$/.test(expectedDigest) ||
+    actualDigest !== expectedDigest
+  ) {
+    throw new Error('Verified artifact digest does not match recovery manifest')
+  }
+
+  return {
+    schemaVersion: 1,
+    recoveryManifestCid: requiredText(
+      recoveryManifest.recoveryManifestCid,
+      'Recovery manifest CID'
+    ),
+    lastKnownGoodEcosystemCid: requiredText(
+      recoveryManifest.lastKnownGoodEcosystemCid,
+      'Last-known-good ecosystem CID'
+    ),
+    previousReleaseManifestCid: requiredText(
+      recoveryManifest.releaseManifestCid,
+      'Previous release manifest CID'
+    ),
+    previousSourceCid: requiredText(
+      recoveryManifest.previousSourceCid,
+      'Previous source CID'
+    ),
+    verifiedArtifactSha256: actualDigest,
+    stagedArtifactPath: requiredText(
+      stagedArtifactPath,
+      'Staged artifact path'
+    ),
+    compatibilityMetadataCid: requiredText(
+      recoveryManifest.compatibilityMetadataCid,
+      'Compatibility metadata CID'
+    ),
+    rollbackInstructionsCid: requiredText(
+      recoveryManifest.rollbackInstructionsCid,
+      'Rollback instructions CID'
+    ),
+    chainRpcAvailable: chainRpcAvailable === true,
+    onChainRevertAvailable:
+      chainRpcAvailable === true &&
+      recoveryManifest.chainRpcRequiredForOnChainRevert === true,
+    explicitUserConfirmationRequired: true,
+    unattendedInstallEnabled: false,
+    unattendedRollbackEnabled: false,
+    state: 'verified_staged_plan',
+  }
+}
+
+export function simulateConfirmedLocalRollback(plan, {confirmed = false} = {}) {
+  if (
+    !plan ||
+    plan.schemaVersion !== 1 ||
+    plan.state !== 'verified_staged_plan'
+  ) {
+    throw new Error('A verified staged rollback plan is required')
+  }
+  if (confirmed !== true) {
+    throw new Error('Explicit local rollback confirmation is required')
+  }
+
+  return {
+    ...plan,
+    state: 'simulation_complete',
+    simulationOnly: true,
+    filesChanged: false,
+    processesRestarted: false,
+    canonicalReferenceChanged: false,
+    onChainRevertExecuted: false,
+  }
+}
+
+export function createExperimentalGovernanceState(epoch = 0) {
+  const governanceEpoch = Number.isSafeInteger(Number(epoch))
+    ? Number(epoch)
+    : 0
+
+  return {
+    localTestData: true,
+    governanceEpoch,
+    phase: 'ReviewOpen',
+    frozenProposalSetRoot: `local-test-root-epoch-${governanceEpoch}`,
+    schedule: {
+      cutoffLabel: '12 blocks',
+      commitLabel: '40 blocks',
+      revealLabel: '60 blocks',
+      graceLabel: '60 blocks after finalization',
+    },
+    reviewSummary: {
+      reviewed: 1,
+      unresolved: 1,
+      aiReviews: 3,
+      commitState: 'Not committed',
+      revealState: 'Not revealed',
+    },
+    proposalSlot: {
+      available: true,
+      label: `Proposal slot for epoch ${governanceEpoch}`,
+      explanation:
+        "Submitting an on-chain proposal uses the identity's only proposal slot for this epoch.",
+    },
+    votingPower: {
+      snapshotReady: true,
+      weighting: 'Sublinear locked IDNA stake; identity age ignored',
+    },
+    recovery: {
+      chainRpcAvailable: false,
+      recoveryManifestCid: 'local-test-recovery-manifest-cid',
+      lastKnownGoodEcosystemCid: 'local-test-known-good-ecosystem-cid',
+      releaseManifestCid: 'local-test-release-manifest-cid',
+      previousSourceCid: 'local-test-source-cid',
+      artifactSha256: 'a'.repeat(64),
+      compatibilityMetadataCid: 'local-test-compatibility-cid',
+      rollbackInstructionsCid: 'local-test-rollback-instructions-cid',
+      chainRpcRequiredForOnChainRevert: true,
+    },
+    proposals: [
+      {
+        proposalId: 'local-proposal-001',
+        title: 'Deterministic source package fixture',
+        proposer: 'local-test-identity-a',
+        repositories: ['fixture/source-a'],
+        riskClass: 'normal',
+        baseCid: 'bafy-local-base-001',
+        candidateCid: 'bafy-local-candidate-001',
+        bond: '100 local-test IDNA',
+        proposalBondAtoms: '100000000000000000000',
+        summary: 'Changes one harmless fixture in the deterministic package.',
+        importantChangedFiles: ['fixture/source-a/example.js'],
+        unresolvedCriticalFindings: 0,
+        testEvidence: ['Fixture package verification passed locally.'],
+        aiFindings: [
+          'AI-generated: no critical finding in the selected fixture context.',
+        ],
+        discussionClaims: ['Local test discussion has no verified claims.'],
+      },
+      {
+        proposalId: 'local-proposal-002',
+        title: 'Cross-repository lock fixture',
+        proposer: 'local-test-identity-b',
+        repositories: ['fixture/source-a', 'fixture/source-b'],
+        riskClass: 'critical',
+        baseCid: 'bafy-local-base-002',
+        candidateCid: 'bafy-local-candidate-002',
+        bond: '250 local-test IDNA',
+        proposalBondAtoms: '250000000000000000000',
+        summary: 'Updates two fixture pins as one candidate ecosystem.',
+        importantChangedFiles: [
+          'fixture/source-a/lock.json',
+          'fixture/source-b/lock.json',
+        ],
+        unresolvedCriticalFindings: 1,
+        testEvidence: [
+          'Builder attestation is still missing in local test data.',
+        ],
+        aiFindings: [
+          'AI-generated: review the compatibility pin before choosing a ballot option.',
+        ],
+        discussionClaims: [
+          'One local test participant requested more replay tests.',
+        ],
+      },
+    ],
+  }
+}
diff --git a/renderer/shared/utils/epoch-governance.test.js b/renderer/shared/utils/epoch-governance.test.js
